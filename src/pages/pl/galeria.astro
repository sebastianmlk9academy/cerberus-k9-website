---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import { GalleryGrid } from '../../components/GalleryGrid';
import { Footer } from '../../components/Footer';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const cmsNavLinks = await loadCmsNavLinks();

const lang = 'pl';
const title = 'Galeria — CERBERUS K9 2025 | Zdjęcia i Wideo z Ćwiczeń K9';
const description =
	'Galeria zdjęć i wideo z CERBERUS K9 2025 — Terminal LPG, Stena Line, Muzeum Gryf. 300+ profesjonalnych fotografii.';

const categoryPriority = [
	'HARDEST_HIT',
	'SZKOLENIA_K9',
	'PIERWSZA_POMOC',
	'TCCC',
	'KONFERENCJA',
	'DRONY',
	'CEREMONIA',
	'SAR',
	'OGOLNE',
] as const;

const scorePhoto = (photo: {
	tags?: string[];
	category: string;
	edition: string;
	order?: number;
}) => {
	const tags = (photo.tags ?? []).map((tag) => tag.toLowerCase());
	const hasHeroTag = tags.some((tag) => ['hero', 'cover', 'best', 'featured', 'main'].includes(tag));
	const categoryIndex = categoryPriority.indexOf(photo.category as (typeof categoryPriority)[number]);
	return (
		(hasHeroTag ? 1000 : 0) +
		(photo.edition === '2025' ? 200 : 0) +
		(categoryIndex >= 0 ? 100 - categoryIndex : 0) +
		(100 - (photo.order ?? 99))
	);
};

const galleryContentFiles = import.meta.glob('/src/content/galeria/**/*.{md,mdx,json,yaml,yml}');
const hasGalleryContent = Object.keys(galleryContentFiles).length > 0;

let allGalleryItems: Awaited<ReturnType<typeof getCollection<'galeria'>>> = [];
if (hasGalleryContent) {
	try {
		allGalleryItems = await getCollection('galeria', ({ data }) => data.active !== false);
	} catch {
		// Keep page renderable even if content parsing fails.
	}
}

// Filtry galerii z CMS
let cmsGalleryFilters: {
	key: string;
	label_pl: string;
	label_en: string;
	label_de: string;
	category_value: string;
}[] = [];
try {
	const rawGF = await getCollection('gallery_filters');
	cmsGalleryFilters = rawGF
		.filter((f) => f.data.active !== false)
		.sort((a, b) => (a.data.order ?? 10) - (b.data.order ?? 10))
		.map((f) => ({
			key: f.data.key,
			label_pl: f.data.label_pl,
			label_en: f.data.label_en ?? f.data.label_pl,
			label_de: f.data.label_de ?? f.data.label_pl,
			category_value: f.data.category_value ?? '',
		}));
} catch {
	console.warn('gallery_filters not loaded, using hardcode fallback');
}

let cmsGalleryEditions: { value: string; label: string }[] = [];
try {
	const rawEditions = await getCollection('galleryEditions');
	cmsGalleryEditions = rawEditions
		.filter((e) => e.data.active !== false)
		.sort((a, b) => (a.data.order ?? 10) - (b.data.order ?? 10))
		.map((e) => ({
			value: e.data.value,
			label: e.data.label_pl,
		}));
} catch {
	console.warn('gallery_editions not loaded, using fallback');
}

let cmsGalleryLocations: { value: string; label: string }[] = [];
try {
	const rawLocations = await getCollection('galleryLocations');
	cmsGalleryLocations = rawLocations
		.filter((l) => l.data.active !== false)
		.sort((a, b) => (a.data.order ?? 10) - (b.data.order ?? 10))
		.map((l) => ({
			value: l.data.value,
			label: l.data.label_pl,
		}));
} catch {
	console.warn('gallery_locations not loaded, using fallback');
}

const photos = allGalleryItems
	.filter((i) => !i.data.media_type || i.data.media_type === 'photo')
	.sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
	.map((i) => ({
		title: i.data.title ?? '',
		category: i.data.category ?? 'OGOLNE',
		location: i.data.location ?? '',
		edition: i.data.edition ?? '2026',
		photo: i.data.photo ?? '',
		alt: i.data.alt ?? i.data.title ?? '',
		tags: i.data.tags ?? [],
		order: i.data.order ?? 100,
	}))
	.filter((p) => p.photo.trim() !== '');

const cmsVideoItems = allGalleryItems
	.filter((i) => i.data.media_type === 'video' && i.data.video_url)
	.sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
	.map((i) => ({
		title: i.data.title ?? '',
		url: i.data.video_url ?? '',
		thumbnail: i.data.video_thumbnail ?? '',
		badge: i.data.press_outlet ?? '',
	}));

const pressItems = allGalleryItems
	.filter((i) => i.data.media_type === 'press')
	.sort((a, b) => (a.data.order ?? 100) - (b.data.order ?? 100))
	.map((i) => ({
		outlet: i.data.press_outlet ?? '',
		outlet_logo: i.data.press_outlet_logo ?? '',
		url: i.data.press_url ?? '',
		date: i.data.press_date ?? '',
		description: i.data.press_description ?? '',
		title: i.data.title ?? '',
	}));

const existingVideoItemsFromSettings = [
	{ title: s?.gallery_video_1_title, url: s?.gallery_video_1_url, badge: s?.gallery_video_1_badge },
	{ title: s?.gallery_video_2_title, url: s?.gallery_video_2_url, badge: s?.gallery_video_2_badge },
	{ title: s?.gallery_video_3_title, url: s?.gallery_video_3_url, badge: s?.gallery_video_3_badge },
	{ title: s?.gallery_video_4_title, url: s?.gallery_video_4_url, badge: s?.gallery_video_4_badge },
].filter((v) => v.url);

const videoItems = cmsVideoItems.length > 0 ? cmsVideoItems : existingVideoItemsFromSettings;

const bestGalleryPhoto = [...photos].sort((a, b) => scorePhoto(b) - scorePhoto(a))[0];
const ogImage = bestGalleryPhoto?.photo ?? '/images/page_hero_graph.webp';
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	canonicalHref="/pl/galeria"
	omitLocaleAlternates
	ogType="website"
	ogImage={ogImage}
>
	<Fragment slot="head">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
	</Fragment>

	<div style="background: linear-gradient(to bottom, #161F28, #1A2530, #161F28); min-height: 100vh;">
		<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
		<PageHero
			category={s?.pagehero_gallery_category_pl || 'ARCHIWUM FOTOGRAFICZNE'}
			title={s?.pagehero_gallery_title_pl || 'GALERIA'}
			subtitle={s?.pagehero_gallery_subtitle_pl || 'EDYCJA 2025 · TRÓJMIASTO · 300+ ZDJĘĆ'}
			heroImage={s?.hero_background_image}
			heroOpacity={s?.hero_background_opacity}
		/>
		<GalleryGrid
			client:visible
			lang={lang}
			photos={photos}
			cmsFilters={cmsGalleryFilters.length > 0 ? cmsGalleryFilters : undefined}
			cmsEditions={cmsGalleryEditions.length > 0 ? cmsGalleryEditions : undefined}
			cmsLocations={cmsGalleryLocations.length > 0 ? cmsGalleryLocations : undefined}
			unlockDate={s?.gallery_unlock_date}
			videoItems={videoItems}
			pressItems={pressItems}
		/>
		<Footer
			lang={lang}
			logoSrc={s?.nav_logo}
			logoAlt={s?.nav_logo_alt}
			brandName={s?.brand_name}
			brandTagline={s?.brand_tagline}
			email={s?.footer_email ?? s?.registration_contact_email}
			phone={s?.footer_phone ?? s?.contact_phone_sebastian}
			socialFacebook={s?.social_facebook}
			socialYoutube={s?.social_youtube}
			socialInstagram={s?.social_instagram}
			socialLinkedin={s?.social_linkedin}
			socialTwitter={s?.social_twitter}
			address={s?.footer_address}
			foundationName={s?.footer_foundation_name}
			domains={s?.footer_domains}
			krsNumber={s?.krs_number}
			nipNumber={s?.nip_number}
			regonNumber={s?.regon_number}
			footerLinks={{
				about: s?.footer_link_about,
				instructors: s?.footer_link_instructors,
				registration: s?.footer_link_registration,
				program: s?.footer_link_program,
				gallery: s?.footer_link_gallery,
				media: s?.footer_link_media,
				news: s?.footer_link_news,
				foundation: s?.footer_link_foundation,
				partners: s?.footer_link_partners,
				contact: s?.footer_link_contact,
			}}
		/>
	</div>

	<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
	<script is:inline>
		const lightbox = GLightbox({ selector: '.glightbox' });
	</script>
</BaseLayout>
