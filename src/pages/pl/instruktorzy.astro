---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { instructorsSeoByLang } from '../../i18n/instructorsSeo';
import { footerCopyByLang } from '../../i18n/footer';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import InstructorsGrid from '../../components/InstructorsGrid';
import { Footer } from '../../components/Footer';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;

const lang = 'pl';
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const seo = instructorsSeoByLang[lang] ?? instructorsSeoByLang['pl'];

let visibleInstructors = [];
try {
	const all = await getCollection('instruktorzy');
	visibleInstructors = all
		.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
		.map(i => ({
			name: i.data.name,
			country: i.data.country,
			countryCode: i.data.countryCode,
			specializations: i.data.specializations ?? [],
			bioShort: i.data.bioShort ?? '',
			bioFull: i.data.bioFull ?? '',
			photo: i.data.photo ?? '',
			order: i.data.order ?? 99,
			type: i.data.type ?? 'Instruktor',
			module: i.data.module ?? '',
			schedule: i.data.schedule ?? '',
			languages: i.data.languages ?? 'Polski',
			linkedinUrl: i.data.linkedinUrl ?? '',
			unit: i.data.unit ?? '',
		}));
} catch (e) {
	console.warn('instruktorzy collection error:', e.message);
}

const instructorsCount = visibleInstructors.length;
const countriesCount = new Set(visibleInstructors.map((instructor) => instructor.countryCode)).size;
---

<BaseLayout
	lang={lang}
	title={seo.title}
	description={seo.description}
	localizedPath="instruktorzy"
	ogType="website"
>
	<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} />
	<PageHero
		category="NASI"
		title="INSTRUKTORZY"
		subtitle="WETERANI JWK · ODDZIAŁU SPECJALNEGO ŻANDARMERII WOJSKOWEJ · POLICJANCI · JSPEC · EKSPERCI NATO"
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>

	<section class="team-intro">
		<p>
			Nasi instruktorzy to elita — emeryci Jednostki Wojskowej Komandosów (JWK), weterani operacji NATO,
			certyfikowani specjaliści K9 ze Stanów Zjednoczonych, Słowacji, Czech i Węgier. Łączy ich jedno:
			realna, bojowa wiedza przekazywana bezpośrednio uczestnikom CERBERUS K9.
		</p>
	</section>

	<section class="count-bar">
		<p>{instructorsCount} INSTRUKTORÓW Z {countriesCount} KRAJÓW</p>
	</section>

	<InstructorsGrid client:load lang={lang} instructors={visibleInstructors} placeholderPhoto={s?.instructor_placeholder_photo} />
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email}
		phone={s?.footer_phone}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		client:load
	/>
</BaseLayout>

<style>
	.team-intro {
		background: linear-gradient(to bottom, #161F28, #1A2530, #161F28);
		padding: 48px 5%;
	}

	.team-intro p {
		max-width: 1200px;
		margin: 0 auto;
		font-family: var(--font-libre-baskerville), 'Libre Baskerville', serif;
		font-size: 15px;
		line-height: 1.8;
		color: #7a8a96;
	}

	.count-bar {
		background: #151e28;
		padding: 0 5% 48px;
	}

	.count-bar p {
		max-width: 1200px;
		margin: 0 auto;
		font-family: var(--font-rajdhani), 'Rajdhani', sans-serif;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.18em;
		color: #c4922a;
		text-transform: uppercase;
	}
</style>
