---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import MediaPage from '../../components/MediaPage';
import { Footer } from '../../components/Footer';
import { footerCopyByLang } from '../../i18n/footer';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';
import { extractThumbnail } from '../../lib/extractThumbnail';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const kontaktContent = await getEntry('kontakt_content', 'kontakt_content');
const kc = kontaktContent?.data;
const cmsNavLinks = await loadCmsNavLinks();

const archiveEntries = await getCollection('media_archive');
const pressReleaseEntries = await getCollection('press_releases');
const mediaArchive = archiveEntries
	.filter((e) => e.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((e) => ({
		outlet: e.data.outlet,
		description: e.data.description ?? '',
		date: e.data.date ?? '',
		href: e.data.link ?? '#',
		badge: e.data.badge ?? 'VIDEO',
		outletLogo: e.data.outlet_logo ?? null,
		thumbnail: extractThumbnail(e.data.link ?? '', e.data.thumbnail ?? null),
	}));

const pressReleases = archiveEntries
	.filter((e) => e.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((e) => ({
		date: e.data.date ?? '',
		title: e.data.outlet,
		href: e.data.link ?? '#',
	}));

const cmsPressReleases = pressReleaseEntries
	.filter((e) => e.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((e) => ({
		date: e.data.date ?? '',
		title: e.data.title,
		href: e.data.file_url,
	}));

const lang = 'pl';
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const title = 'Media — CERBERUS K9 2026 | Press Kit, Informacje Prasowe, Akredytacja';
const description =
	'Materiały prasowe CERBERUS K9 2026. Pobierz press kit, logo, zdjęcia i informacje prasowe. Kontakt dla mediów.';
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	canonicalHref="/pl/media"
	omitLocaleAlternates
	ogType="website"
>
	<div
		style="background: linear-gradient(to bottom, #161F28, #1A2530, #161F28); min-height: 100vh;"
	>
		<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
		<PageHero
			category="DLA DZIENNIKARZY"
			title="MEDIA"
			subtitle="PRESS KIT · INFORMACJE PRASOWE · RELACJE 2025"
			heroImage={s?.hero_background_image}
			heroOpacity={s?.hero_background_opacity}
		/>
		<!-- Canonical media-contact source: kontakt_content. Global settings stay as legacy fallback. -->
		<MediaPage
			client:load
			lang={lang}
			mediaArchive={mediaArchive}
			pressReleases={cmsPressReleases.length > 0 ? cmsPressReleases : pressReleases}
			accreditationDeadline={kc?.accreditation_deadline ?? s?.accreditation_deadline}
			pressKitItems={[
				{
					title: 'Polska Zbrojna — Reportaż CERBERUS K9 2025',
					description: 'Reportaż Wojskowego Instytutu Wydawniczego',
					href: s?.press_pdf_polska_zbrojna ?? '#',
					type: 'pdf' as const,
				},
				{
					title: 'Special Ops — Relacja CERBERUS K9 2025',
					description: 'Relacja kwartalnika Defence24',
					href: s?.press_pdf_special_ops ?? '#',
					type: 'pdf' as const,
				},
			]}
			pressZipHref={s?.press_kit_zip || undefined}
			pressKitZip={s?.press_kit_zip}
			pressPdfPolskaZbrojna={s?.press_pdf_polska_zbrojna}
			pressPdfSpecialOps={s?.press_pdf_special_ops}
			mediaContactName={kc?.media_contact_name ?? s?.media_contact_name}
			mediaContactPhone={kc?.media_contact_phone ?? s?.media_contact_phone}
			mediaContactEmail={kc?.media_contact_email ?? s?.media_contact_email}
			mediaLabelsPl={{
				fullMaterials: s?.media_label_full_materials_pl,
				contactAccreditation: s?.media_label_contact_accreditation_pl,
				pressInfo: s?.media_label_press_info_pl,
				mediaArchive: s?.media_label_media_archive_pl,
				archiveDescription: s?.media_label_archive_description_pl,
			}}
		/>
		<Footer
			lang={lang}
			copy={footerCopy}
			logoSrc={s?.nav_logo}
			logoAlt={s?.nav_logo_alt}
			brandName={s?.brand_name}
			brandTagline={s?.brand_tagline}
			email={s?.footer_email ?? s?.registration_contact_email}
			phone={s?.footer_phone ?? s?.contact_phone_sebastian}
			socialFacebook={s?.social_facebook}
			socialYoutube={s?.social_youtube}
			socialInstagram={s?.social_instagram}
			socialLinkedin={s?.social_linkedin}
			socialTwitter={s?.social_twitter}
			address={s?.footer_address}
			foundationName={s?.footer_foundation_name}
			domains={s?.footer_domains}
			krsNumber={s?.krs_number}
			nipNumber={s?.nip_number}
			regonNumber={s?.regon_number}
			footerLinks={{
				about: s?.footer_link_about,
				instructors: s?.footer_link_instructors,
				registration: s?.footer_link_registration,
				program: s?.footer_link_program,
				gallery: s?.footer_link_gallery,
				media: s?.footer_link_media,
				news: s?.footer_link_news,
				foundation: s?.footer_link_foundation,
				partners: s?.footer_link_partners,
				contact: s?.footer_link_contact,
			}}
		/>
	</div>
</BaseLayout>
