---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { HOME_OG_IMAGE } from '../../i18n/homeSeo';
import { aboutEventPageByLang } from '../../i18n/aboutEventPage';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import InteractiveAgenda from '../../components/InteractiveAgenda';
import { LocationsSection } from '../../components/LocationsSection';
import FAQAccordion from '../../components/FAQAccordion';
import { Footer } from '../../components/Footer';
import { footerCopyByLang } from '../../i18n/footer';
import { locationsSectionByLang } from '../../i18n/locationsSection';
import { programEntriesToAgendaItems } from '../../lib/programAgenda';
import type { AgendaCategory } from '../../lib/agendaCategories';
import { locationEntriesToItems } from '../../lib/eventLocations';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';

export const prerender = true;

const lang = 'pl';
const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const cmsNavLinks = await loadCmsNavLinks();
const agendaUiEntry = await getEntry('agenda_ui', 'labels');
const agendaUi = agendaUiEntry?.data;
const fundacjaContent = await getEntry('fundacja_content', 'content');
const fc = fundacjaContent?.data;
const agendaUILabels = {
	addToCalendar: (agendaUi?.add_to_calendar as Record<string, string> | undefined)?.[lang] ?? 'DODAJ DO KALENDARZA',
	navigate: (agendaUi?.navigate as Record<string, string> | undefined)?.[lang] ?? 'NAWIGUJ',
	noLocation: (agendaUi?.no_location as Record<string, string> | undefined)?.[lang] ?? 'BRAK PODPIĘTEJ LOKALIZACJI',
	noEvents: (agendaUi?.no_events as Record<string, string> | undefined)?.[lang] ?? 'BRAK WYDARZEŃ',
	googleCalendar: (agendaUi?.google_calendar as Record<string, string> | undefined)?.[lang] ?? 'GOOGLE CALENDAR',
	appleIcal: (agendaUi?.apple_ical as Record<string, string> | undefined)?.[lang] ?? 'APPLE / ICAL',
	instructorLabel: (agendaUi?.instructor_label as Record<string, string> | undefined)?.[lang] ?? 'PROWADZĄCY:',
	icsOrganizerName: agendaUi?.ics_organizer_name ?? 'Fundacja PACTA K9',
	icsOrganizerEmail: agendaUi?.ics_organizer_email ?? 'sebastian@pactak9.org',
	icsProdid: agendaUi?.ics_prodid ?? '-//CERBERUS K9//PL',
};
const copy = aboutEventPageByLang[lang] ?? aboutEventPageByLang['pl'];
const bodyP1 = fc?.about_body_p1_pl ?? copy.bodyP1;
const bodyP2 = fc?.about_body_p2_pl ?? copy.bodyP2;
const aboutStats = [
	{
		value: fc?.about_stat_1_value ?? copy.stats[0].value,
		label: fc?.about_stat_1_label_pl ?? copy.stats[0].label,
		accent: copy.stats[0].accent,
	},
	{
		value: fc?.about_stat_2_value ?? copy.stats[1].value,
		label: fc?.about_stat_2_label_pl ?? copy.stats[1].label,
		accent: copy.stats[1].accent,
	},
	{
		value: fc?.about_stat_3_value ?? copy.stats[2].value,
		label: fc?.about_stat_3_label_pl ?? copy.stats[2].label,
		accent: copy.stats[2].accent,
	},
	{
		value: fc?.about_stat_4_value ?? copy.stats[3].value,
		label: fc?.about_stat_4_label_pl ?? copy.stats[3].label,
		accent: copy.stats[3].accent,
	},
];
const plausibleDomain = s?.plausible_domain ?? 'cerberusk9.org';
const siteOrigin = s?.site_url ?? new URL(Astro.site!).origin;
const startDate = s?.event_date ?? '2026-06-13';
const endDate = s?.event_date_end ?? '2026-06-14';
const formatDay = (dateStr: string, locale: string) => {
	return new Date(dateStr).toLocaleDateString(locale, {
		day: 'numeric',
		month: 'long',
	}).toUpperCase();
};
const agendaHeading =
	lang === 'pl'
		? `AGENDA WYDARZENIA — ${
				new Date(startDate).getDate()
		  }–${formatDay(endDate, 'pl-PL')} ${
				new Date(startDate).getFullYear()
		  }`
		: `EVENT AGENDA — ${
				new Date(startDate).getDate()
		  }–${formatDay(endDate, 'en-GB')} ${
				new Date(startDate).getFullYear()
		  }`;
const eventName = `CERBERUS K9 ${new Date(startDate).getFullYear()}`;

const programEntries = await getCollection('program');
const categoryEntries = await getCollection('agenda_categories');
const agendaCategories: AgendaCategory[] = categoryEntries
	.filter((c) => c.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((c) => ({
		key: c.data.key,
		label_pl: c.data.label_pl,
		label_en: c.data.label_en ?? c.data.label_pl,
		color: c.data.color,
		show_in_filter: c.data.show_in_filter ?? true,
		show_calendar_button: c.data.show_calendar_button ?? true,
		order: c.data.order ?? 99,
	}));
const { days: agendaDays, categoryMeta } = programEntriesToAgendaItems(
	programEntries.filter((e) => e.data.active !== false),
	lang,
	agendaCategories,
);
const agendaFilters = [
	{ key: 'ALL', label: lang === 'pl' ? 'WSZYSTKO' : 'ALL' },
	...agendaCategories.filter((c) => c.show_in_filter).map((c) => ({
		key: c.key,
		label: lang === 'pl' ? c.label_pl : (c.label_en ?? c.label_pl),
	})),
];
const faqEntries = await getCollection('faq');
const faqItems = faqEntries
	.filter((e) => e.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((e) => ({
		question: lang === 'pl' ? e.data.question_pl : (e.data.question_en ?? e.data.question_pl),
		answer: lang === 'pl' ? e.data.answer_pl : (e.data.answer_en ?? e.data.answer_pl),
	}));
const locationsData = await getCollection('locations');
const locationItems = locationsData.length > 0
	? locationEntriesToItems(locationsData, lang)
	: null;

const eventSchema = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: 'CERBERUS K9 2026',
	startDate: s?.event_date ?? '2026-06-13',
	endDate: s?.event_date_end ?? '2026-06-14',
	eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
	eventStatus: 'https://schema.org/EventScheduled',
	location: {
		'@type': 'Place',
		name: s?.event_venue ?? '3MK Arena',
		address: {
			'@type': 'PostalAddress',
			addressLocality: s?.event_city ?? 'Ostrów Wielkopolski',
			addressCountry: 'PL',
		},
	},
	organizer: {
		'@type': 'Organization',
		name: 'Fundacja PACTA K9',
		url: siteOrigin,
	},
	description: copy.metaDescription,
	image: [new URL(HOME_OG_IMAGE, Astro.site ?? Astro.url).toString()],
	url: Astro.url.toString(),
};
---

<BaseLayout
	lang={lang}
	title={copy.metaTitle}
	description={copy.metaDescription}
	localizedPath="o-wydarzeniu"
	ogImage={HOME_OG_IMAGE}
	ogType="website"
>
	<script defer data-domain={plausibleDomain} src="https://plausible.io/js/plausible.js"></script>
	<script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

	<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<PageHero
		category={copy.category}
		title={copy.heroTitle}
		subtitle={copy.heroSubtitle}
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>

	<section class="event-description" aria-labelledby="event-desc-heading" style={{ paddingTop: '10px' }}>
		<div class="event-description__inner">
			<div class="event-description__col event-description__col--main">
				<h2 id="event-desc-heading" class="event-description__title">
					{(() => {
						const heading = copy.sectionTitle;
						const parts = heading.split('K9');
						const suffix = (parts[1] ?? '').replace(/^\s+([?!:;,.])/u, '$1');
						const leadingPunctuationMatch = suffix.match(/^[?!:;,.]/u);
						const leadingPunctuation = leadingPunctuationMatch?.[0] ?? '';
						const suffixWithoutLeadingPunctuation = leadingPunctuation ? suffix.slice(1) : suffix;
						return (
							<>
								{parts[0]}
								<span style={{ color: '#C42B2B' }}>K9</span>{`${leadingPunctuation}${suffixWithoutLeadingPunctuation}`}
							</>
						);
					})()}
				</h2>
				<p class="event-description__body">{bodyP1}</p>
				<p class="event-description__body">{bodyP2}</p>
			</div>
			<div class="event-description__col event-description__col--stats">
				<div class="event-description__grid items-center">
					{
						aboutStats.map((stat) => (
							<div
								class:list={[
									'event-description__stat',
									stat.accent === 'gold' && 'event-description__stat--gold',
									stat.accent === 'red' && 'event-description__stat--red',
								]}
							>
								<p class="event-description__stat-value">{stat.value}</p>
								<p class="event-description__stat-label">{stat.label}</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<InteractiveAgenda
		client:load
		items={agendaDays}
		categoryMeta={categoryMeta}
		filters={agendaFilters}
		categories={agendaCategories}
		lang={lang}
		agendaHeading={agendaHeading}
		eventName={eventName}
		city={s?.event_city}
		agendaUrl={s?.agenda_page_url}
		uiLabels={agendaUILabels}
	/>
	<LocationsSection
		copy={locationsSectionByLang[lang] ?? locationsSectionByLang['pl']}
		locations={locationItems ?? undefined}
		lang={lang}
		client:load
	/>
	<FAQAccordion client:load lang={lang} faqItems={faqItems} />
	<Footer
		lang={lang}
		copy={footerCopyByLang[lang] ?? footerCopyByLang['pl']}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>

<style>
	.event-description {
		background: linear-gradient(to bottom, #161F28, #1A2530, #161F28);
		padding: 0 5%;
		margin: 0;
		border-top: none;
		border-bottom: none;
	}
	.event-description__inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}
	@media (min-width: 1024px) {
		.event-description__inner {
			flex-direction: row;
			align-items: center;
			gap: 4rem;
		}
		.event-description__col--main {
			flex: 0 0 60%;
			max-width: 60%;
		}
		.event-description__col--stats {
			flex: 0 0 40%;
			max-width: 40%;
		}
	}
	.event-description__title {
		font-family: var(--font-bebas-neue), 'Bebas Neue', sans-serif;
		font-size: 42px;
		line-height: 1.1;
		color: #e4ddd0;
		margin: 0 0 1.5rem;
		letter-spacing: 0.02em;
	}
	.event-description__body {
		font-family: var(--font-libre-baskerville), 'Libre Baskerville', Georgia, serif;
		font-size: 15px;
		line-height: 1.8;
		color: #7a8a96;
		margin: 0 0 1.25rem;
	}
	.event-description__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}
	.event-description__stat {
		background: rgba(15, 23, 32, 0.65);
		border: 1px solid #253344;
		border-left-width: 4px;
		padding: 1.25rem 1rem;
		min-height: 120px;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.event-description__stat--gold {
		border-left-color: #c4922a;
	}
	.event-description__stat--red {
		border-left-color: #c42b2b;
	}
	.event-description__stat-value {
		font-family: var(--font-bebas-neue), 'Bebas Neue', sans-serif;
		font-size: 2.75rem;
		line-height: 1;
		color: #e4ddd0;
		margin: 0 0 0.5rem;
		letter-spacing: 0.04em;
	}
	.event-description__stat-label {
		font-family: var(--font-rajdhani), 'Rajdhani', sans-serif;
		font-size: 10px;
		font-weight: 600;
		letter-spacing: 0.12em;
		color: #7a8a96;
		margin: 0;
		text-transform: uppercase;
		line-height: 1.35;
	}
</style>
