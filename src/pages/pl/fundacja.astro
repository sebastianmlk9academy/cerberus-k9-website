---
/**
 * Hosting: configure OVH MultiSite so the domain pactak9.org serves this site and maps the host
 * to the `/fundacja` path (path-based multisite / subdirectory on the same hosting).
 * Primary event site can remain on cerberusk9.org; the foundation microsite uses this page.
 */
import { getCollection, getEntry } from 'astro:content';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import TeamSection from '../../components/TeamSection';
import { Footer } from '../../components/Footer';
import { footerCopyByLang } from '../../i18n/footer';
import { fundacjaPageByLang } from '../../i18n/plOnlyPagesCopy';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const statuteHref = s?.statute_pdf ?? '#';
const krsHref = s?.krs_url ?? '#';

const fundacjaContent = await getEntry('fundacja_content', 'content');
const fc = fundacjaContent?.data;
const cmsNavLinks = await loadCmsNavLinks();

const lang = 'pl';
const fundacjaCopy = fundacjaPageByLang['pl'];
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const title = fundacjaCopy.metaTitle;
const description = fundacjaCopy.metaDescription;

const statutoryGoals: string[] = (fc?.goals_pl ?? []).map((g) => g.goal);

const legalRows: { label: string; value: string }[] = [
	{ label: 'KRS', value: '0001219121' },
	{ label: 'NIP', value: '6222869581' },
	{ label: 'REGON', value: '543799847' },
	{ label: 'Sąd rejestrowy', value: fc?.registration_court ?? 'Sąd Rejonowy w Ostrowie Wielkopolskim' },
	{ label: 'Data rejestracji', value: fc?.registration_date ?? '2024' },
	{ label: 'Adres', value: 'ul. Odolanowska 17, 63-400 Topola Mała, woj. wielkopolskie' },
	{
		label: 'Prezes',
		value: 'Mariusz Lis',
	},
	{ label: 'Wiceprezes', value: 'Sebastian Bożek' },
	{ label: 'Status', value: fc?.legal_status_pl ?? 'Fundacja, osobowość prawna' },
	{ label: 'Działalność', value: 'Non-profit, art. 3 ustawy o fundacjach' },
];
let teamMembers = [];
try {
	teamMembers = await getCollection('team');
} catch (e) {
	console.warn('team collection:', e instanceof Error ? e.message : String(e));
}
const members = teamMembers
	.sort((a,b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((m) => ({
		name: m.data.name,
		role: m.data.role,
		photo: m.data.photo ?? s?.instructor_placeholder_photo ?? '',
		unit: m.data.unit ?? '',
		bioShort: m.data.bio_short,
		email: m.data.email ?? '',
	}));
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	canonicalHref="/pl/fundacja"
	omitLocaleAlternates
	ogType="website"
>
	<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<PageHero
		category={s?.pagehero_foundation_category_pl || 'O NAS'}
		title={s?.pagehero_foundation_title_pl || 'FUNDACJA PACTA K9'}
		subtitle={s?.pagehero_foundation_subtitle_pl || 'KRS: 0001219121 · TOPOLA MAŁA · WIELKOPOLSKA'}
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>

	<section class="fundacja-mission" aria-labelledby="fundacja-misja-heading">
		<div class="fundacja-mission__inner">
			<div class="fundacja-mission__col">
				<h2 id="fundacja-misja-heading" class="fundacja-mission__title fundacja-mission__title--gold">
					MISJA
				</h2>
				<p class="fundacja-mission__body">{fc?.mission_pl?.replace(/\s+/g, ' ').trim()}</p>
			</div>
			<div class="fundacja-mission__col">
				<h2 class="fundacja-mission__title fundacja-mission__title--red">WIZJA</h2>
				<p class="fundacja-mission__body">{fc?.vision_pl?.replace(/\s+/g, ' ').trim()}</p>
			</div>
		</div>
	</section>

	<TeamSection members={members} client:load />

	<section class="fundacja-legal" aria-labelledby="fundacja-legal-heading">
		<div class="fundacja-legal__inner">
			<h2 id="fundacja-legal-heading" class="fundacja-legal__heading">DANE REJESTROWE I FORMALNE</h2>

			<dl class="fundacja-legal__table">
				{
					legalRows.map((row) => (
						<div class="fundacja-legal__pair">
							<dt>{row.label}</dt>
							<dd>{row.value}</dd>
						</div>
					))
				}
			</dl>

			<div class="fundacja-legal__cta-row">
				<a class="fundacja-legal__cta fundacja-legal__cta--partner" href={statuteHref}>
					Pobierz Statut Fundacji
				</a>
				<a class="fundacja-legal__cta fundacja-legal__cta--partner" href={krsHref} target="_blank" rel="noopener noreferrer">
					Sprawdź w KRS ↗
				</a>
			</div>

			<div class="fundacja-statute" aria-labelledby="fundacja-statute-heading">
				<h3 id="fundacja-statute-heading" class="fundacja-statute__heading">Cele statutowe — §5 Statutu</h3>
				<p class="fundacja-statute__intro">Celami szczegółowymi Fundacji są w szczególności:</p>
				<ol class="fundacja-statute__list">
					{statutoryGoals.map((text) => <li>{text}</li>)}
				</ol>
			</div>
		</div>
	</section>

	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>

<style>
	.fundacja-mission {
		background-color: #151e28;
		padding: 64px 5%;
	}
	.fundacja-mission__inner {
		max-width: 72rem;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}
	@media (min-width: 768px) {
		.fundacja-mission__inner {
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
		}
	}
	.fundacja-mission__title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2rem, 4vw, 2.75rem);
		letter-spacing: 0.12em;
		color: #e4ddd0;
		margin: 0 0 1.25rem;
		padding-bottom: 0.75rem;
		border-bottom: 3px solid transparent;
		line-height: 1.1;
	}
	.fundacja-mission__title--gold {
		border-bottom-color: #c4922a;
	}
	.fundacja-mission__title--red {
		border-bottom-color: #c42b2b;
	}
	.fundacja-mission__body {
		font-family: 'Libre Baskerville', serif;
		font-size: 0.95rem;
		line-height: 1.75;
		color: #7a8a96;
		margin: 0;
	}

	.fundacja-legal {
		background-color: #151e28;
		padding: 48px 5%;
	}
	.fundacja-legal__inner {
		max-width: 48rem;
		margin: 0 auto;
	}
	.fundacja-legal__heading {
		font-family: var(--font-rajdhani), 'Rajdhani', sans-serif;
		font-size: 1.5rem;
		line-height: 2rem;
		font-weight: 700;
		letter-spacing: 2px;
		color: #e4ddd0;
		text-transform: uppercase;
		margin: 0 0 2rem;
		text-align: center;
	}
	@media (min-width: 640px) {
		.fundacja-legal__heading {
			font-size: 1.875rem;
			line-height: 2.25rem;
		}
	}
	@media (min-width: 1024px) {
		.fundacja-legal__heading {
			font-size: 32px;
		}
	}
	.fundacja-legal__table {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin: 0 0 2rem;
		font-family: 'Rajdhani', sans-serif;
		font-size: 0.9375rem;
		line-height: 1.45;
	}
	.fundacja-legal__pair {
		display: grid;
		grid-template-columns: minmax(6.5rem, 28%) 1fr;
		gap: 0 1.25rem;
		align-items: start;
	}
	.fundacja-legal__table dt {
		margin: 0;
		font-weight: 700;
		letter-spacing: 0.06em;
		color: #c4922a;
		text-transform: uppercase;
		font-size: 0.75rem;
	}
	.fundacja-legal__table dd {
		margin: 0;
		color: #b8c4ce;
		font-weight: 500;
	}
	.fundacja-legal__cta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		margin-bottom: 3rem;
	}
	.fundacja-legal__cta {
		display: flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		text-transform: uppercase;
		cursor: pointer;
		box-sizing: border-box;
	}
	.fundacja-legal__cta--partner {
		width: 100%;
		padding: 12px 20px;
		font-family: var(--font-rajdhani), sans-serif;
		font-size: 10px;
		font-weight: 700;
		letter-spacing: 3px;
		color: #c4922a;
		background-color: transparent;
		border: 1px solid #c4922a;
		border-radius: 0;
		transition-property: color, background-color, border-color;
		transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
		transition-duration: 150ms;
	}
	@media (min-width: 640px) {
		.fundacja-legal__cta--partner {
			width: auto;
			padding: 14px 24px;
			font-size: 11px;
		}
	}
	.fundacja-legal__cta--partner:hover {
		background-color: #c4922a;
		color: #1e2b38;
	}
	.fundacja-statute__heading {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.5rem;
		letter-spacing: 0.1em;
		color: #e4ddd0;
		margin: 0 0 0.75rem;
	}
	.fundacja-statute__intro {
		font-family: 'Rajdhani', sans-serif;
		font-size: 0.8125rem;
		color: #7a8a96;
		margin: 0 0 1.25rem;
		letter-spacing: 0.04em;
	}
	.fundacja-statute__list {
		margin: 0;
		padding-left: 1.25rem;
		font-family: 'Libre Baskerville', serif;
		font-size: 0.875rem;
		line-height: 1.65;
		color: #5a6a7a;
	}
	.fundacja-statute__list li {
		margin-bottom: 0.65rem;
		padding-left: 0.35rem;
	}
	.fundacja-statute__list li::marker {
		color: #c42b2b;
		font-weight: 700;
	}
</style>
