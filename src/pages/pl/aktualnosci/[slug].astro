---
import { type CollectionEntry, getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { NavBar } from '../../../components/NavBar';
import { ArticleLayout } from '../../../components/ArticleLayout';
import { Footer } from '../../../components/Footer';
import { newsSeoByLang } from '../../../i18n/newsSeo';
import { footerCopyByLang } from '../../../i18n/footer';
import { categoryBadgeLabel, formatNewsDateLabel } from '../../../lib/aktualnosci';
import { getSortedNavLinks } from '../../../lib/getSortedNavLinks';

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getCollection('aktualnosci', ({ data }) => data.draft !== true);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

type Props = { post: CollectionEntry<'aktualnosci'> };

const lang = 'pl';
const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const navLinks = await getSortedNavLinks(lang);
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const seoLang = newsSeoByLang[lang] ?? newsSeoByLang['pl'];
const { post } = Astro.props;
const { Content } = await render(post);

const dateLabel = formatNewsDateLabel(post.data.date, lang);
const dateIso = post.data.date.toISOString().slice(0, 10);
const pageTitle = post.data.seo_title ?? post.data.title;
const pageDesc = post.data.seo_description ?? post.data.lead;
const pageOgImage =
	post.data.og_image_override?.trim() ||
	post.data.image?.trim() ||
	s?.og_image_default ||
	'/og-cerberus-k9-2026.jpg';
const canonicalPath = `/pl/aktualnosci/${post.id}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? Astro.url).href;
const siteOrigin = s?.site_url ?? new URL(Astro.site!).origin;
const shareUrl =
	post.data.share_url?.trim() && /^https?:\/\//i.test(post.data.share_url.trim())
		? post.data.share_url.trim()
		: canonicalUrl;

const hero =
	post.data.image?.trim() && post.data.image_alt?.trim()
		? { src: post.data.image.trim(), alt: post.data.image_alt.trim() }
		: post.data.image?.trim()
			? { src: post.data.image.trim(), alt: post.data.title }
			: undefined;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'NewsArticle',
	headline: pageTitle,
	description: pageDesc,
	datePublished: post.data.date.toISOString(),
	image: hero ? [new URL(hero.src, Astro.site ?? Astro.url).href] : undefined,
	url: canonicalUrl,
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalUrl,
	},
	publisher: {
		'@type': 'Organization',
		name: 'CERBERUS K9',
		url: siteOrigin,
	},
};
---

<BaseLayout
	lang={lang}
	title={pageTitle}
	description={pageDesc}
	localizedPath={`aktualnosci/${post.id}`}
	ogImage={pageOgImage}
	ogType="article"
	twitterCard="summary_large_image"
	canonicalHref={canonicalUrl}
>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} links={navLinks} activeHref={Astro.url.pathname} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<ArticleLayout
		lang="pl"
		breadcrumb={[
			{ label: 'CERBERUS K9', href: `/${lang}/` },
			{ label: seoLang.breadcrumbNews, href: `/${lang}/aktualnosci/` },
			{ label: post.data.title },
		]}
		category={categoryBadgeLabel(post.data.category, lang)}
		date={dateLabel}
		dateTime={dateIso}
		title={post.data.title}
		lead={post.data.lead}
		heroImage={hero}
		tags={post.data.tags ?? []}
		shareUrl={shareUrl}
		shareTitle={post.data.title}
		backHref={`/${lang}/aktualnosci/`}
	>
		<Content />
	</ArticleLayout>
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>
