---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { NavBar } from '../../../components/NavBar';
import { PageHero } from '../../../components/PageHero';
import { NewsListing } from '../../../components/NewsListing';
import { Footer } from '../../../components/Footer';
import { newsSeoByLang } from '../../../i18n/newsSeo';
import { footerCopyByLang } from '../../../i18n/footer';
import { aktualnosciToListingArticles } from '../../../lib/aktualnosci';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;

const lang = 'pl';
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const seo = newsSeoByLang[lang] ?? newsSeoByLang['pl'];
const entries = await getCollection('aktualnosci');
const articles = aktualnosciToListingArticles(entries, lang);
---

<BaseLayout
	lang={lang}
	title={seo.title}
	description={seo.description}
	localizedPath="aktualnosci"
	ogType="website"
>
	<NavBar client:load lang={lang} />
	<PageHero
		category="CERBERUS K9"
		title="AKTUALNOŚCI"
		subtitle="WIADOMOŚCI, KOMUNIKATY I RELACJE Z PRZYGOTOWAŃ DO WYDARZENIA"
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>
	<NewsListing articles={articles} lang={lang} client:load />
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email}
		phone={s?.footer_phone}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		client:load
	/>
</BaseLayout>
