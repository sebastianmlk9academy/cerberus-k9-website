---
import { getEntry } from 'astro:content';
import { getSortedNavLinks } from '../../lib/getSortedNavLinks';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import { ContactPage } from '../../components/ContactPage';
import { Footer } from '../../components/Footer';
import { footerCopyByLang } from '../../i18n/footer';

export const prerender = true;

const lang = 'pl';

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const kontaktContent = await getEntry('kontakt_content', 'kontakt_content');
const kc = kontaktContent?.data;

const navLinks = await getSortedNavLinks(lang);

const zipCity = [s?.contact_address_zip?.trim(), s?.contact_address_city?.trim()].filter(Boolean).join(' ');
const contactStreet = s?.contact_address_street?.trim();
const contactAddressLine =
	[contactStreet, zipCity].filter(Boolean).join(', ') || 'ul. Odolanowska 17, 63-400 Topola Mała';

const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const title = 'Kontakt — Fundacja PACTA K9 | CERBERUS K9 2026';
const description = 'Skontaktuj się z Fundacją PACTA K9 i zespołem CERBERUS K9 2026.';
---

<BaseLayout lang={lang} title={title} description={description} localizedPath="kontakt" ogType="website">
	<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} links={navLinks} activeHref={Astro.url.pathname} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<PageHero
		category={s?.pagehero_contact_category_pl || 'KONTAKT'}
		title={s?.pagehero_contact_title_pl || 'SKONTAKTUJ SIĘ'}
		subtitle={s?.pagehero_contact_subtitle_pl || 'FUNDACJA PACTA K9 · CERBERUS K9 2026'}
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>
	<!-- Canonical contact source: kontakt_content. Global settings stay as legacy fallback. -->
	<ContactPage
		lang={lang}
		email={kc?.contact_email ?? s?.footer_email ?? s?.registration_contact_email}
		phone={(kc?.contact_phone ?? s?.contact_phone_sebastian) || '+48 695 637 907'}
		address={contactAddressLine}
		mapEmbedUrl={kc?.contact_map_embed_url ?? s?.contact_map_embed_url}
		venueAddress={s?.contact_venue_address}
		presidentEmail={
			kc?.president_email ||
			s?.contact_president_email ||
			s?.president_email ||
			'mariusz@pactak9.org'
		}
		contactFormEndpoint={kc?.contact_form_endpoint ?? s?.contact_form_endpoint}
		contactFormRecipient={kc?.contact_form_recipient ?? s?.contact_form_recipient}
		gdprConsentText={kc?.contact_gdpr_text_pl ?? s?.contact_gdpr_text_pl}
		formLabels={{
			name: kc?.form_name_label_pl,
			email: kc?.form_email_label_pl,
			subject: kc?.form_subject_label_pl,
			message: kc?.form_message_label_pl,
			submit: kc?.form_submit_label_pl,
			success: kc?.form_success_pl,
			error: kc?.form_error_pl,
			subjectOptions: kc?.form_subject_options_pl,
			sectionMedia: kc?.section_media_title_pl,
			sectionPartnership: kc?.section_partnership_title_pl,
		}}
		client:load
	/>
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>
