---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { HeroSection } from '../../components/HeroSection';
import { StatsBar } from '../../components/StatsBar';
import { ProgramSection } from '../../components/ProgramSection';
import { LocationsSection } from '../../components/LocationsSection';
import { VideoSection } from '../../components/VideoSection';
import { PartnersStrip } from '../../components/PartnersStrip';
import LatestNews from '../../components/LatestNews';
import { Footer } from '../../components/Footer';
import { HOME_OG_IMAGE, homeSeoByLang } from '../../i18n/homeSeo';

export const prerender = true;

const lang = 'pl';
const seo = homeSeoByLang[lang];

const eventSchema = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: seo.eventName,
	startDate: '2026-06-13',
	endDate: '2026-06-14',
	eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
	eventStatus: 'https://schema.org/EventScheduled',
	location: {
		'@type': 'Place',
		name: '3MK Arena Ostrów Wielkopolski',
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Ostrów Wielkopolski',
			addressCountry: 'PL',
		},
	},
	organizer: {
		'@type': 'Organization',
		name: 'Fundacja PACTA K9',
		url: 'https://cerberusk9.org',
	},
	description: seo.description,
	image: [new URL(HOME_OG_IMAGE, Astro.site ?? Astro.url).toString()],
	url: Astro.url.toString(),
};
---

<BaseLayout
	lang={lang}
	title={seo.title}
	description={seo.description}
	localizedPath=""
	ogImage={HOME_OG_IMAGE}
	ogType="website"
>
	<script
		defer
		data-domain="cerberusk9.org"
		src="https://plausible.io/js/plausible.js"
	></script>
	<script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

	<NavBar client:load />
	<HeroSection client:load />
	<StatsBar client:load />
	<ProgramSection client:load />
	<LocationsSection client:load />
	<VideoSection client:load />
	<PartnersStrip client:load />
	<LatestNews client:load />
	<Footer client:load />
</BaseLayout>
