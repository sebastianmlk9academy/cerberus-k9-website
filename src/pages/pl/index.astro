---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { HeroSection } from '../../components/HeroSection';
import { StatsBar } from '../../components/StatsBar';
import { ProgramSection } from '../../components/ProgramSection';
import { LocationsSection } from '../../components/LocationsSection';
import { VideoSection } from '../../components/VideoSection';
import { PartnersStrip } from '../../components/PartnersStrip';
import LatestNews from '../../components/LatestNews';
import { Footer } from '../../components/Footer';
import { homeSeoByLang } from '../../i18n/homeSeo';
import { homeHeroCopyByLang } from '../../i18n/homeHero';
import { footerCopyByLang } from '../../i18n/footer';
import { homeStatsByLang } from '../../i18n/homeStats';
import { statsEntriesToStatItems } from '../../lib/homepageStats';
import { programSectionByLang } from '../../i18n/programSection';
import { cardEntriesToProgramCards } from '../../lib/homepageCards';
import { partnerEntriesToStripItems } from '../../lib/partnersStrip';
import { locationsSectionByLang } from '../../i18n/locationsSection';
import { videoSectionByLang } from '../../i18n/videoSection';
import { latestNewsByLang } from '../../i18n/latestNews';
import { partnersStripByLang } from '../../i18n/partnersStrip';
import { ui } from '../../i18n/ui';
import { aktualnosciToListingArticles } from '../../lib/aktualnosci';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const cmsNavLinks = await loadCmsNavLinks();

const allArticles = await getCollection('aktualnosci');
const latestForListing = aktualnosciToListingArticles(allArticles, 'pl').slice(0, 3).map((a) => ({
	slug: a.slug ?? a.id,
	image: a.imageSrc ?? '/images/cerberus-k9-logo.png',
	category: a.categoryLabel,
	title: a.title,
	lead: a.lead,
	date: a.date,
}));

const plausibleDomain = s?.plausible_domain ?? 'cerberusk9.org';
const twitterHandle = s?.twitter_handle ?? '@cerberusk9';

const lang = 'pl';
const seo = homeSeoByLang[lang] ?? homeSeoByLang['pl'];
const safeUi = ui[lang] ?? ui.pl;
const seoTitle = safeUi.meta_title_home ?? seo.title;
const seoDescription = safeUi.meta_desc_home ?? seo.description;
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const statsEntries = await getCollection('homepage_stats');
const statsCopy =
	statsEntries.length > 0
		? statsEntriesToStatItems(statsEntries, lang, {
				participants_count: s?.participants_count,
				countries_count: s?.countries_count,
			})
		: (homeStatsByLang[lang] ?? homeStatsByLang['pl']).map((item, i) => ({
				...item,
				value:
					i === 0
						? (s?.participants_count ?? item.value)
						: i === 1
							? (s?.countries_count ?? item.value)
							: item.value,
			}));

const partnersData = await getCollection('partnerzy');
const cardEntries = await getCollection('homepage_cards');
const stripPartners = partnerEntriesToStripItems(partnersData);
const programCopy = programSectionByLang[lang] ?? programSectionByLang['pl'];
const locationsCopy = locationsSectionByLang[lang] ?? locationsSectionByLang['pl'];
const programCards =
	cardEntries.length > 0 ? cardEntriesToProgramCards(cardEntries, lang) : null;
const videoCopy = videoSectionByLang[lang] ?? videoSectionByLang['pl'];
const newsCopy = latestNewsByLang[lang] ?? latestNewsByLang['pl'];

const eventImagePath = s?.og_image_default ?? '/og-cerberus-k9-2026.jpg';
const eventJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: `CERBERUS K9 ${new Date(s?.event_date ?? '2026-06-13').getFullYear()}`,
	startDate: `${s?.event_date ?? '2026-06-13'}T${s?.event_time_start ?? '09:00'}:00`,
	endDate: `${s?.event_date_end ?? '2026-06-14'}T${s?.event_time_end ?? '18:00'}:00`,
	eventStatus: 'https://schema.org/EventScheduled',
	eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
	location: {
		'@type': 'Place',
		name: s?.event_venue ?? '3MK Arena',
		address: {
			'@type': 'PostalAddress',
			streetAddress: s?.venue_address ?? '',
			addressLocality: s?.event_city ?? 'Ostrów Wielkopolski',
			addressCountry: 'PL',
		},
	},
	organizer: {
		'@type': 'Organization',
		name: s?.footer_foundation_name ?? 'Fundacja PACTA K9',
		url: s?.site_url ?? 'https://cerberusk9.org',
	},
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'PLN',
		availability: 'https://schema.org/InStock',
		url: s?.pretix_url ?? '',
	},
	image: new URL(eventImagePath, Astro.site ?? Astro.url).href,
	url: s?.site_url ?? 'https://cerberusk9.org',
};
---

<BaseLayout
	lang={lang}
	title={seoTitle}
	description={seoDescription}
	localizedPath=""
	ogImage={s?.og_image_default ?? '/og-cerberus-k9-2026.jpg'}
	ogType="website"
	twitterHandle={twitterHandle}
>
	<script defer data-domain={plausibleDomain} src="https://plausible.io/js/plausible.js"></script>
	<script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />

	<NavBar lang={lang} client:load navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<HeroSection
		lang={lang}
		copy={homeHeroCopyByLang[lang] ?? homeHeroCopyByLang['pl']}
		eventDate={s?.event_date}
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
		eventTimeStart={s?.event_time_start ?? '10:00'}
		eventTimezone={s?.event_timezone ?? 'Europe/Warsaw'}
		heroTagline={s?.hero_tagline}
		heroSublinePl={s?.hero_subline_pl}
		heroTitleLine1={s?.hero_title_line1 ?? s?.hero_title}
		heroTitleLine2={s?.hero_title_line2 ?? s?.hero_subtitle}
		heroYear={s?.hero_year}
		heroVideoHref={s?.hero_video_href ?? s?.main_video_youtube}
		heroVideoTitle={s?.hero_video_title}
		heroCloseLabelPl={s?.hero_close_label_pl}
		heroMetaLocations={s?.hero_meta_locations}
		heroMetaDelegations={s?.hero_meta_delegations}
		heroMetaEntry={s?.hero_meta_entry}
		ctaRegistrationHref={
			s?.hero_cta_registration_href?.trim() ||
				s?.pretix_url?.trim() ||
				`/${lang}/rejestracja`
		}
		ctaProgramHref={s?.hero_cta_program_href?.trim() || `/${lang}/o-wydarzeniu#agenda`}
		registrationActive={s?.registration_active ?? true}
		client:load
	/>
	<StatsBar lang={lang} stats={statsCopy} client:load />
	<ProgramSection lang={lang} copy={programCopy} cards={programCards ?? undefined} client:load />
	<LocationsSection lang={lang} copy={locationsCopy} client:load />
	<VideoSection
		lang={lang}
		copy={videoCopy}
		mainVideoUrl={s?.main_video_youtube}
		mainVideoTitle={s?.main_video_title}
		videoBadge1={s?.video_badge_1}
		video2Url={s?.video_url_2}
		video2Badge={s?.video_badge_2}
		video3Url={s?.video_url_3}
		video3Badge={s?.video_badge_3}
		video4Url={s?.video_url_4}
		video4Badge={s?.video_badge_4}
		client:load
	/>
	<PartnersStrip
		copy={partnersStripByLang[lang] ?? partnersStripByLang['pl']}
		partners={stripPartners}
		partnerCtaHref={s?.partner_cta_href}
		client:load
	/>
	<LatestNews lang={lang} copy={newsCopy} articles={latestForListing} client:load />
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>
