---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { HeroSection } from '../../components/HeroSection';
import { StatsBar } from '../../components/StatsBar';
import { ProgramSection } from '../../components/ProgramSection';
import { LocationsSection } from '../../components/LocationsSection';
import { VideoSection } from '../../components/VideoSection';
import { PartnersStrip } from '../../components/PartnersStrip';
import LatestNews from '../../components/LatestNews';
import { WallOfFame } from '../../components/WallOfFame';
import { CerberusTimeline } from '../../components/CerberusTimeline';
import { Footer } from '../../components/Footer';
import { homeSeoByLang } from '../../i18n/homeSeo';
import { footerCopyByLang } from '../../i18n/footer';
import { homeStatsByLang } from '../../i18n/homeStats';
import { statsEntriesToStatItems } from '../../lib/homepageStats';
import { programSectionByLang } from '../../i18n/programSection';
import type { AgendaCategory } from '../../lib/agendaCategories';
import { programEntriesToHomepageCards } from '../../lib/programToHomepageCards';
import { partnerEntriesToStripItems } from '../../lib/partnersStrip';
import { locationsSectionByLang } from '../../i18n/locationsSection';
import { videoSectionByLang } from '../../i18n/videoSection';
import { latestNewsByLang } from '../../i18n/latestNews';
import { partnersStripByLang } from '../../i18n/partnersStrip';
import { ui } from '../../i18n/ui';
import { aktualnosciToListingArticles } from '../../lib/aktualnosci';
import { getSortedNavLinks } from '../../lib/getSortedNavLinks';

export const prerender = true;

const lang = 'pl';

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data || {};

const allArticles = await getCollection('aktualnosci');
const latestForListing = aktualnosciToListingArticles(allArticles, 'pl').slice(0, 3).map((a) => ({
	slug: a.slug ?? a.id,
	image: a.imageSrc ?? '/images/cerberus-k9-logo.png',
	category: a.categoryLabel,
	title: a.title,
	lead: a.lead,
	date: a.date,
}));

const plausibleDomain = (s?.plausible_domain ?? '').trim();
const twitterHandle = (s?.twitter_handle ?? '').trim() || undefined;

const navLinks = await getSortedNavLinks(lang);
const seo = homeSeoByLang[lang] ?? homeSeoByLang['pl'];
const safeUi = ui[lang] ?? ui.pl;
const seoTitle = safeUi.meta_title_home ?? seo.title;
const seoDescription = safeUi.meta_desc_home ?? seo.description;
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const statsEntries = await getCollection('homepage_stats');
const statsCopy =
	statsEntries.length > 0
		? statsEntriesToStatItems(statsEntries, lang, {
				participants_count: s?.participants_count,
				countries_count: s?.countries_count,
			})
		: (homeStatsByLang[lang] ?? homeStatsByLang['pl']).map((item, i) => ({
				...item,
				value:
					i === 0
						? (s?.participants_count ?? item.value)
						: i === 1
							? (s?.countries_count ?? item.value)
							: item.value,
			}));

const partnersData = await getCollection('partnerzy');
const programEntries = await getCollection('program');
const categoryEntries = await getCollection('agenda_categories');
const agendaCategoriesForCards: AgendaCategory[] = categoryEntries
	.filter((c) => c.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((c) => ({
		key: c.data.key,
		label_pl: c.data.label_pl,
		label_en: c.data.label_en ?? c.data.label_pl,
		color: c.data.color,
		show_in_filter: c.data.show_in_filter ?? true,
		show_calendar_button: c.data.show_calendar_button ?? true,
		order: c.data.order ?? 99,
	}));
const programCards = programEntriesToHomepageCards(programEntries, lang, s?.event_date, {
	limit: 6,
	categories: agendaCategoriesForCards,
});
const stripPartners = partnerEntriesToStripItems(partnersData);
const programCopy = programSectionByLang[lang] ?? programSectionByLang['pl'];
const locationsCopy = locationsSectionByLang[lang] ?? locationsSectionByLang['pl'];
const videoCopy = videoSectionByLang[lang] ?? videoSectionByLang['pl'];
const newsCopy = latestNewsByLang[lang] ?? latestNewsByLang['pl'];

const timeline = (await getCollection('timeline'))
	.filter((t) => t.data.isVisible !== false)
	.sort((a, b) => a.data.order - b.data.order)
	.map((t) => t.data);

const testimonials = (await getCollection('testimonials'))
	.filter((t) => t.data.isVisible !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((t) => ({
		...t.data,
		name_pl: t.data.author_name ?? t.data.name_pl ?? '',
		name_en: t.data.author_name ?? t.data.name_en ?? '',
	}));

const rawParticipantsNum = Number.parseInt(String(s?.participants_count ?? '').replace(/\D/g, ''), 10);
const heroParticipantsMax =
	Number.isFinite(rawParticipantsNum) && rawParticipantsNum > 0 ? rawParticipantsNum : undefined;

const eventImagePath = s?.og_image_default ?? '/og-cerberus-k9-2026.jpg';
const siteOrigin = (s?.site_url && String(s.site_url).replace(/\/$/, '')) || new URL(Astro.site ?? Astro.url).origin;
const eventJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: seoTitle,
	...(s?.event_date && s?.event_time_start
		? { startDate: `${s.event_date}T${s.event_time_start}:00` }
		: {}),
	...(s?.event_date_end && s?.event_time_end ? { endDate: `${s.event_date_end}T${s.event_time_end}:00` } : {}),
	eventStatus: 'https://schema.org/EventScheduled',
	eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
	location: {
		'@type': 'Place',
		name: s?.event_venue ?? '',
		address: {
			'@type': 'PostalAddress',
			streetAddress: s?.venue_address ?? '',
			addressLocality: s?.event_city ?? '',
			addressCountry: 'PL',
		},
	},
	organizer: {
		'@type': 'Organization',
		name: s?.footer_foundation_name ?? '',
		url: siteOrigin,
	},
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'PLN',
		availability: 'https://schema.org/InStock',
		url: (s?.pretix_url ?? s?.registration_url ?? '').trim(),
	},
	image: new URL(eventImagePath, Astro.site ?? Astro.url).href,
	url: siteOrigin,
};
---

<BaseLayout
	lang={lang}
	title={seoTitle}
	description={seoDescription}
	localizedPath=""
	ogImage={s?.og_image_default ?? '/og-cerberus-k9-2026.jpg'}
	ogType="website"
	twitterHandle={twitterHandle}
>
	{plausibleDomain ? <script defer data-domain={plausibleDomain} src="https://plausible.io/js/plausible.js" /> : null}
	<script type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />

	<NavBar lang={lang} client:visible links={navLinks} activeHref={Astro.url.pathname} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<HeroSection
		client:load
		lang={lang}
		eventDate={s.event_date_display}
		eventDateISO={s.event_date}
		location={s.event_location ?? s.hero_meta_locations}
		tagline={s.event_tagline ?? s.hero_tagline}
		subtitle={s.hero_subtitle}
		registrationUrl={s.registration_url?.trim() || s.pretix_url?.trim() || s.hero_cta_registration_href?.trim()}
		registrationActive={s.registration_active ?? true}
		showLiveCounter={s?.show_live_counter ?? false}
		participantsMax={heroParticipantsMax}
		eventTimeStart={s?.event_time_start}
		eventTimezone={s?.event_timezone}
		heroImage={s.hero_background_image}
		heroOpacity={s.hero_background_opacity}
		heroTitle={s.hero_title_line1 ?? s.hero_title}
		heroTitleLine2={s.hero_title_line2}
		heroYear={s.hero_year}
		heroSublinePl={s.hero_subline_pl}
		heroVideoHref={s.hero_video_href ?? s.main_video_youtube}
		heroVideoTitle={s.hero_video_title}
		heroCloseLabelPl={s.hero_close_label_pl}
		heroMetaDelegations={s.hero_meta_delegations}
		heroMetaEntry={s.hero_meta_entry}
		ctaProgramHref={s.hero_cta_program_href?.trim() || `/${lang}/o-wydarzeniu#agenda`}
	/>
	<StatsBar lang={lang} stats={statsCopy} client:visible />
	<CerberusTimeline client:visible nodes={timeline} lang={lang} />
	<ProgramSection lang={lang} copy={programCopy} cards={programCards.length > 0 ? programCards : undefined} client:visible />
	<LocationsSection lang={lang} copy={locationsCopy} client:visible />
	<VideoSection
		lang={lang}
		copy={videoCopy}
		mainVideoUrl={s?.main_video_youtube}
		mainVideoTitle={s?.main_video_title}
		videoBadge1={s?.video_badge_1}
		video2Url={s?.video_url_2}
		video2Badge={s?.video_badge_2}
		video3Url={s?.video_url_3}
		video3Badge={s?.video_badge_3}
		video4Url={s?.video_url_4}
		video4Badge={s?.video_badge_4}
		client:visible
	/>
	<PartnersStrip
		copy={partnersStripByLang[lang] ?? partnersStripByLang['pl']}
		partners={stripPartners}
		partnerCtaHref={s?.partner_cta_href}
		client:visible
	/>
	<WallOfFame client:visible testimonials={testimonials} lang={lang} />
	<LatestNews lang={lang} copy={newsCopy} articles={latestForListing} client:visible />
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>
