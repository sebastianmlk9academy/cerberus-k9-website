---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import PartnersPage, { type Partner, type PartnerTypeId } from '../../components/PartnersPage';
import { Footer } from '../../components/Footer';
import { footerCopyByLang } from '../../i18n/footer';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const cmsNavLinks = await loadCmsNavLinks();

const lang = 'pl';
const footerCopy = footerCopyByLang[lang] ?? footerCopyByLang['pl'];
const title = 'Partnerzy CERBERUS K9 | Sponsorzy i Patronat Medialny';
const description =
	'Partnerzy strategiczni, sponsorzy i patroni medialni wydarzenia CERBERUS K9 — instytucje i firmy współtworzące szkolenia K9 oraz rozwój kompetencji służb mundurowych.';

const entries = await getCollection('partnerzy', ({ data }) => data.active !== false);
const sorted = [...entries].sort((a, b) => (a.data.order ?? 9999) - (b.data.order ?? 9999));

function websiteLabel(url: string | undefined): string | null {
	if (!url?.trim()) return null;
	const href = /^https?:\/\//i.test(url) ? url : `https://${url}`;
	try {
		return new URL(href).hostname.replace(/^www\./i, '');
	} catch {
		return url;
	}
}

function cmsTypeToPartnerType(
	t:
		| 'Strategiczny'
		| 'Sponsor'
		| 'Patron-Medialny'
		| 'Patron Medialny'
		| 'Technologiczny'
		| undefined,
): PartnerTypeId {
	if (t === 'Patron-Medialny' || t === 'Patron Medialny') return 'media';
	if (t === 'Sponsor') return 'sponsor';
	if (t === 'Technologiczny') return 'technology';
	if (t === 'Strategiczny') return 'strategic';
	return 'strategic';
}

function displayName(entry: (typeof sorted)[number]): string {
	const n = entry.data.name?.trim();
	if (n) return n;
	return entry.id
		.replace(/\.md$/i, '')
		.split('-')
		.map((w) => (w.length ? w.charAt(0).toUpperCase() + w.slice(1) : ''))
		.join(' ');
}

const rawPS = await getCollection('partner_sections');
const cmsPartnerSections = rawPS
	.filter((e) => e.data.active !== false)
	.sort((a, b) => (a.data.order ?? 10) - (b.data.order ?? 10))
	.map((e) => ({ ...e.data }));

const partners: Partner[] = sorted.map((entry, i) => {
	const website = entry.data.website?.trim() || null;
	const labelFromCms = entry.data.website_label?.trim();
	return {
		id: i + 1,
		name: displayName(entry),
		type: cmsTypeToPartnerType(entry.data.type),
		description: entry.data.description?.trim() || '',
		website,
		websiteLabel: labelFromCms || (website ? websiteLabel(website) : null),
		logo: entry.data.logo?.trim() || null,
	};
});
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	canonicalHref="/pl/partnerzy"
	omitLocaleAlternates
	ogType="website"
>
	<div
		style="background: linear-gradient(to bottom, #161F28, #1A2530, #161F28); min-height: 100vh;"
	>
	<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<PageHero
		category="WSPÓŁPRACA"
		title="PARTNERZY"
		subtitle="STRATEGICZNI · SPONSORZY · PATRONI MEDIALNI"
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>
	<PartnersPage
		client:load
		lang={lang}
		partners={partners}
		embedded
		sponsorOfferPdf={s?.sponsor_offer_pdf}
		sponsorContactEmail={s?.sponsor_contact_email}
		cmsSections={cmsPartnerSections}
	/>
	<Footer
		lang={lang}
		copy={footerCopy}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
	</div>
</BaseLayout>
