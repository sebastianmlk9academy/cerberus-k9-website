---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import RegistrationEmbed from '../../components/RegistrationEmbed';
import { Footer } from '../../components/Footer';

export const prerender = true;

const lang = 'pl';
const title = 'Rejestracja — CERBERUS K9 2026 | Bezpłatna rejestracja online';
const description =
	'Zarejestruj się bezpłatnie na CERBERUS K9 2026. 13-14 czerwca, Ostrów Wielkopolski. 250+ uczestników z 15+ krajów NATO.';
---

<BaseLayout lang={lang} title={title} description={description} localizedPath="rejestracja" ogType="website">
	<link
		slot="head"
		rel="stylesheet"
		href="https://pretix.eu/static/pretixwidget/widget.css"
	/>
	<script
		slot="head"
		src="https://pretix.eu/static/pretixwidget/widget.js"
		async
	></script>
	<NavBar client:load />
	<PageHero
		category="DOŁĄCZ DO NAS"
		title="REJESTRACJA"
		subtitle="WSTĘP BEZPŁATNY · WYMAGANA REJESTRACJA · 13–14 CZERWCA 2026"
	/>
	<RegistrationEmbed client:only="react" />
	<Footer client:load />
</BaseLayout>
