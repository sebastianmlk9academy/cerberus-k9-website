---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { NavBar } from '../../components/NavBar';
import InternationalPage from '../../components/InternationalPage';
import { Footer } from '../../components/Footer';
import { getSortedNavLinks } from '../../lib/getSortedNavLinks';
import { footerCopyByLang } from '../../i18n/footer';

export const prerender = true;

const lang = 'en';
const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const navLinks = await getSortedNavLinks(lang);

const heroEntry = await getEntry('international_hero', 'hero');
const protocolEntry = await getEntry('international_protocol', 'protocol');
const contactEntry = await getEntry('international_contact', 'contact');
const faqEntries = await getCollection('international_faq');
const delegations = (await getCollection('delegations'))
  .filter((d) => d.data.confirmed)
  .sort((a, b) => a.data.order - b.data.order)
  .map((d) => d.data);

const hero = heroEntry?.data;
const protocol = protocolEntry?.data.items ?? [];
const contact = contactEntry?.data;
const faq = faqEntries
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map((item) => ({
    question: item.data.question_en,
    answer: item.data.answer_en,
  }));

const registrationHref =
  s?.registration_url?.trim() ||
  s?.pretix_url?.trim() ||
  s?.hero_cta_registration_href?.trim() ||
  '/en/rejestracja';
const programHref = `/en/o-wydarzeniu#program`;

const siteOrigin = (s?.site_url && String(s.site_url).replace(/\/$/, '')) || new URL(Astro.site ?? Astro.url).origin;
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'CERBERUS K9 2026',
  startDate: s?.event_date ?? '2026-06-13',
  endDate: s?.event_date_end ?? '2026-06-14',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: s?.event_venue ?? '3MK Arena',
    address: {
      '@type': 'PostalAddress',
      addressLocality: s?.event_city ?? 'Ostrów Wielkopolski',
      addressCountry: 'PL',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: 'Fundacja PACTA K9',
    url: siteOrigin,
  },
  description:
    hero?.body_en ??
    'CERBERUS K9 welcomes official delegations from NATO member states, partner nations and allied organisations.',
  url: `${siteOrigin}/en/international`,
};
---

<BaseLayout
  lang={lang}
  title="For Delegations — CERBERUS K9 2026"
  description={hero?.body_en ?? 'Official delegation zone for CERBERUS K9 2026.'}
  localizedPath="international"
  canonicalHref="/en/international"
  ogType="website"
>
  <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
  <NavBar lang={lang} client:load logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} links={navLinks} activeHref={Astro.url.pathname} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
  {hero && contact ? (
    <InternationalPage
      client:load
      hero={hero}
      protocol={protocol}
      faq={faq}
      contact={contact}
      lang={lang}
      registrationHref={registrationHref}
      programHref={programHref}
      confirmedDelegations={delegations}
    />
  ) : null}
  <Footer
    lang={lang}
    copy={footerCopyByLang[lang] ?? footerCopyByLang['pl']}
    logoSrc={s?.nav_logo}
    logoAlt={s?.nav_logo_alt}
    brandName={s?.brand_name}
    brandTagline={s?.brand_tagline}
    email={s?.footer_email ?? s?.registration_contact_email}
    phone={s?.footer_phone ?? s?.contact_phone_sebastian}
    socialFacebook={s?.social_facebook}
    socialYoutube={s?.social_youtube}
    socialInstagram={s?.social_instagram}
    socialLinkedin={s?.social_linkedin}
    socialTwitter={s?.social_twitter}
    address={s?.footer_address}
    foundationName={s?.footer_foundation_name}
    domains={s?.footer_domains}
    krsNumber={s?.krs_number}
    nipNumber={s?.nip_number}
    regonNumber={s?.regon_number}
    footerLinks={{
      about: s?.footer_link_about,
      instructors: s?.footer_link_instructors,
      registration: s?.footer_link_registration,
      program: s?.footer_link_program,
      gallery: s?.footer_link_gallery,
      media: s?.footer_link_media,
      news: s?.footer_link_news,
      foundation: s?.footer_link_foundation,
      partners: s?.footer_link_partners,
      contact: s?.footer_link_contact,
    }}
  />
</BaseLayout>
