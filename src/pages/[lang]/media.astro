---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales } from '../../../locales.mjs';
import { isLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { mediaPageByLang } from '../../i18n/plOnlyPagesCopy';
import { ui } from '../../i18n/ui';
import { footerCopyByLang } from '../../i18n/footer';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import MediaPage from '../../components/MediaPage';
import { Footer } from '../../components/Footer';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';

export const prerender = true;

export function getStaticPaths() {
	return locales.filter((l) => l !== 'pl').map((lang) => ({ params: { lang } }));
}

const { lang: paramLang } = Astro.params;
const lang: Lang = isLang(paramLang ?? '') ? (paramLang as Lang) : 'en';
const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const cmsNavLinks = await loadCmsNavLinks();

const archiveEntries = await getCollection('media_archive');
const mediaArchive = archiveEntries
	.filter((e) => e.data.active !== false)
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((e) => ({
		outlet: e.data.outlet,
		description: e.data.description ?? '',
		date: e.data.date ?? '',
		href: e.data.link ?? '#',
		badge: e.data.badge ?? 'VIDEO',
		outletLogo: e.data.outlet_logo ?? null,
	}));

const copy = mediaPageByLang[lang] ?? mediaPageByLang['pl'];
const navMedia = (ui[lang] ?? ui['pl']).nav_media;
---

<BaseLayout
	lang={lang}
	title={copy.metaTitle}
	description={copy.metaDescription}
	localizedPath="media"
	ogType="website"
	canonicalHref={`/${lang}/media`}
>
	<div
		style="background: linear-gradient(to bottom, #161F28, #1A2530, #161F28); min-height: 100vh;"
	>
		<NavBar client:load lang={lang} logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
		<PageHero
			category={copy.heroCategory}
			title={navMedia}
			subtitle={copy.heroSubtitle}
			heroImage={s?.hero_background_image}
			heroOpacity={s?.hero_background_opacity}
		/>
		<MediaPage
			client:load
			lang={lang}
			mediaArchive={mediaArchive}
			accreditationDeadline={s?.accreditation_deadline}
			pressKitItems={[
				{
					title: 'Polska Zbrojna — Reportaż CERBERUS K9 2025',
					description: 'Reportaż Wojskowego Instytutu Wydawniczego',
					href: s?.press_pdf_polska_zbrojna ?? '#',
					type: 'pdf' as const,
				},
				{
					title: 'Special Ops — Relacja CERBERUS K9 2025',
					description: 'Relacja kwartalnika Defence24',
					href: s?.press_pdf_special_ops ?? '#',
					type: 'pdf' as const,
				},
			]}
			pressZipHref={s?.press_kit_zip || undefined}
			pressKitZip={s?.press_kit_zip}
			pressPdfPolskaZbrojna={s?.press_pdf_polska_zbrojna}
			pressPdfSpecialOps={s?.press_pdf_special_ops}
			mediaContactName={s?.media_contact_name}
			mediaContactPhone={s?.media_contact_phone}
			mediaContactEmail={s?.media_contact_email}
		/>
		<Footer
			lang={lang}
			copy={footerCopyByLang[lang] ?? footerCopyByLang['pl']}
			logoSrc={s?.nav_logo}
			logoAlt={s?.nav_logo_alt}
			brandName={s?.brand_name}
			brandTagline={s?.brand_tagline}
			email={s?.footer_email ?? s?.registration_contact_email}
			phone={s?.footer_phone ?? s?.contact_phone_sebastian}
			socialFacebook={s?.social_facebook}
			socialYoutube={s?.social_youtube}
			socialInstagram={s?.social_instagram}
			socialLinkedin={s?.social_linkedin}
			socialTwitter={s?.social_twitter}
			address={s?.footer_address}
			foundationName={s?.footer_foundation_name}
			domains={s?.footer_domains}
			krsNumber={s?.krs_number}
			nipNumber={s?.nip_number}
			regonNumber={s?.regon_number}
		/>
	</div>
</BaseLayout>
