---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales } from '../../../locales.mjs';
import { isLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { instructorsSeoByLang } from '../../i18n/instructorsSeo';
import { instructorsPageByLang } from '../../i18n/instructorsPage';
import { footerCopyByLang } from '../../i18n/footer';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import InstructorsGrid from '../../components/InstructorsGrid';
import { Footer } from '../../components/Footer';
import { getSortedNavLinks } from '../../lib/getSortedNavLinks';

export const prerender = true;

export function getStaticPaths() {
	return locales.filter((locale) => locale !== 'pl').map((lang) => ({ params: { lang } }));
}

const param = Astro.params.lang ?? '';
const lang: Lang = isLang(param) ? param : 'en';
const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const navLinks = await getSortedNavLinks(lang);
const seo = instructorsSeoByLang[lang] ?? instructorsSeoByLang['pl'];
const instrCopy = instructorsPageByLang[lang] ?? instructorsPageByLang['pl'];

const instructors = (await getCollection('instruktorzy'))
	.filter((e) => (e.data.confirmed ?? 'confirmed') !== 'hidden')
	.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
	.map((i) => ({
		name: i.data.name,
		role: i.data.role ?? i.data.role_pl ?? '',
		country: i.data.country ?? '',
		countryCode:
			i.data.countryCode ?? (i.data as { country_code?: string }).country_code ?? '',
		specializations: i.data.specializations ?? [],
		bioShort: i.data.bioShort ?? (i.data as { bio_short_pl?: string }).bio_short_pl ?? '',
		bioFull: i.data.bioFull ?? (i.data as { bio_full_pl?: string }).bio_full_pl ?? '',
		photo: i.data.photo ?? '',
		order: i.data.order ?? 99,
		type: i.data.type ?? (i.data as { instructor_type?: string }).instructor_type ?? 'Instruktor',
		module: i.data.module ?? '',
		schedule: i.data.schedule ?? '',
		languages: i.data.languages ?? 'Polski',
		linkedinUrl: i.data.linkedinUrl ?? (i.data as { linkedin_url?: string }).linkedin_url ?? '',
		socialFacebook: i.data.socialFacebook ?? '',
		socialInstagram: i.data.socialInstagram ?? '',
		unit: i.data.unit ?? '',
	}));

const rawIF = await getCollection('instructor_filters');
const cmsInstructorFilters = rawIF
	.filter((f) => f.data.active !== false)
	.sort((a, b) => (a.data.order ?? 10) - (b.data.order ?? 10))
	.map((f) => ({ ...f.data }));

const instructorCount = instructors.length;
const countriesCount = new Set(instructors.map((instructor) => instructor.countryCode)).size;
---

<BaseLayout
	lang={lang}
	title={seo.title}
	description={seo.description}
	localizedPath="instruktorzy"
	ogType="website"
>
	<NavBar lang={lang} client:load logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} links={navLinks} activeHref={Astro.url.pathname} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<PageHero
		category="CERBERUS K9"
		title={instrCopy.heroTitle}
		subtitle={instrCopy.heroSubtitle}
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>

	<section class="team-intro">
		<p>{instrCopy.introP}</p>
	</section>

	<section class="count-bar">
		<p>{instructorCount} {instrCopy.countTemplate.replace('{n}', String(countriesCount))}</p>
	</section>

	<InstructorsGrid
		instructors={instructors}
		lang={lang}
		placeholderPhoto={s?.instructor_placeholder_photo}
		cmsFilters={cmsInstructorFilters}
		client:load
	/>
	<Footer
		lang={lang}
		copy={footerCopyByLang[lang] ?? footerCopyByLang['pl']}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>

<style>
	.team-intro {
		background: #151e28;
		padding: 48px 5%;
	}

	.team-intro p {
		max-width: 1200px;
		margin: 0 auto;
		font-family: var(--font-libre-baskerville), 'Libre Baskerville', serif;
		font-size: 15px;
		line-height: 1.8;
		color: #7a8a96;
	}

	.count-bar {
		background: #151e28;
		padding: 0 5% 48px;
	}

	.count-bar p {
		max-width: 1200px;
		margin: 0 auto;
		font-family: var(--font-rajdhani), 'Rajdhani', sans-serif;
		font-size: 14px;
		font-weight: 700;
		letter-spacing: 0.18em;
		color: #c4922a;
		text-transform: uppercase;
	}
</style>
