---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales } from '../../i18n/utils';
import { isLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { HOME_OG_IMAGE, homeSeoByLang } from '../../i18n/homeSeo';
import { homeHeroCopyByLang } from '../../i18n/homeHero';
import { footerCopyByLang } from '../../i18n/footer';
import { homeStatsByLang } from '../../i18n/homeStats';
import { programSectionByLang } from '../../i18n/programSection';
import { locationsSectionByLang } from '../../i18n/locationsSection';
import { videoSectionByLang } from '../../i18n/videoSection';
import { latestNewsByLang } from '../../i18n/latestNews';
import { partnersStripByLang } from '../../i18n/partnersStrip';
import { NavBar } from '../../components/NavBar';
import { HeroSection } from '../../components/HeroSection';
import { StatsBar } from '../../components/StatsBar';
import { ProgramSection } from '../../components/ProgramSection';
import { LocationsSection } from '../../components/LocationsSection';
import { VideoSection } from '../../components/VideoSection';
import { PartnersStrip } from '../../components/PartnersStrip';
import LatestNews from '../../components/LatestNews';
import { Footer } from '../../components/Footer';

export const prerender = true;

export const getStaticPaths = () =>
	locales.filter((locale) => locale !== 'pl').map((lang) => ({ params: { lang } }));

const param = Astro.params.lang ?? '';
const lang: Lang = isLang(param) ? param : 'en';
const seo = homeSeoByLang[lang];
const heroCopy = homeHeroCopyByLang[lang];
const footerCopy = footerCopyByLang[lang];
const statsCopy = homeStatsByLang[lang];
const programCopy = programSectionByLang[lang];
const locationsCopy = locationsSectionByLang[lang];
const videoCopy = videoSectionByLang[lang];
const newsCopy = latestNewsByLang[lang];
const partnersCopy = partnersStripByLang[lang];

const eventSchema = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: seo.eventName,
	startDate: '2026-06-13',
	endDate: '2026-06-14',
	eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
	eventStatus: 'https://schema.org/EventScheduled',
	location: {
		'@type': 'Place',
		name: '3MK Arena Ostrów Wielkopolski',
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Ostrów Wielkopolski',
			addressCountry: 'PL',
		},
	},
	organizer: {
		'@type': 'Organization',
		name: 'Fundacja PACTA K9',
		url: 'https://cerberusk9.org',
	},
	description: seo.description,
	image: [new URL(HOME_OG_IMAGE, Astro.site ?? Astro.url).toString()],
	url: Astro.url.toString(),
};
---

<BaseLayout
	lang={lang}
	title={seo.title}
	description={seo.description}
	localizedPath=""
	ogImage={HOME_OG_IMAGE}
	ogType="website"
>
	<script
		defer
		data-domain="cerberusk9.org"
		src="https://plausible.io/js/plausible.js"
	></script>
	<script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

	<NavBar lang={lang} client:load />
	<HeroSection lang={lang} copy={heroCopy} client:load />
	<StatsBar lang={lang} copy={statsCopy} client:load />
	<ProgramSection lang={lang} copy={programCopy} client:load />
	<LocationsSection lang={lang} copy={locationsCopy} client:load />
	<VideoSection lang={lang} copy={videoCopy} client:load />
	<PartnersStrip lang={lang} copy={partnersCopy} client:load />
	<LatestNews lang={lang} copy={newsCopy} client:load />
	<Footer lang={lang} copy={footerCopy} client:load />
</BaseLayout>
