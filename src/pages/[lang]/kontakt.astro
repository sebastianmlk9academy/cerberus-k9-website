---
import { getEntry } from 'astro:content';
import { loadCmsNavLinks } from '../../lib/loadCmsNavLinks';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales } from '../../../locales.mjs';
import { footerCopyByLang } from '../../i18n/footer';
import { isLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import { ContactPage } from '../../components/ContactPage';
import { Footer } from '../../components/Footer';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const cmsNavLinks = await loadCmsNavLinks();

/** Polish URL is canonical; /pl/kontakt is defined in `src/pages/pl/kontakt.astro`. */
export function getStaticPaths() {
	return locales.filter((l) => l !== 'pl').map((lang) => ({ params: { lang } }));
}

const { lang: paramLang } = Astro.params;
const lang: Lang = isLang(paramLang ?? '') ? (paramLang as Lang) : 'en';
const title = lang === 'pl' ? 'Kontakt — CERBERUS K9' : 'Contact — CERBERUS K9';
const description =
	lang === 'pl'
		? 'Skontaktuj się z Fundacją PACTA K9 i zespołem CERBERUS K9 2026.'
		: 'Get in touch with the PACTA K9 Foundation and the CERBERUS K9 2026 team.';
const canonicalHref = `/${lang}/kontakt`;
const contactHero: Record<Lang, { title: string; subtitle: string }> = {
	pl: { title: 'KONTAKT', subtitle: 'Skontaktuj się z nami, aby uzyskać informacje o wydarzeniu i współpracy.' },
	en: { title: 'CONTACT', subtitle: 'Get in touch with us for event details and partnership inquiries.' },
	de: { title: 'KONTAKT', subtitle: 'Kontaktieren Sie uns für Veranstaltungsdetails und Partnerschaftsanfragen.' },
	fr: { title: 'CONTACT', subtitle: "Contactez-nous pour les détails de l'événement et les demandes de partenariat." },
	hr: { title: 'KONTAKT', subtitle: 'Javite nam se za informacije o događaju i partnerstvu.' },
	cs: { title: 'KONTAKT', subtitle: 'Kontaktujte nás pro informace o akci a partnerské spolupráci.' },
	lt: { title: 'KONTAKTAI', subtitle: 'Susisiekite su mumis dėl renginio informacijos ir partnerystės užklausų.' },
	lv: { title: 'KONTAKTI', subtitle: 'Sazinieties ar mums par pasākuma informāciju un partnerības iespējām.' },
	sk: { title: 'KONTAKT', subtitle: 'Kontaktujte nás pre informácie o podujatí a partnerskej spolupráci.' },
	sl: { title: 'KONTAKT', subtitle: 'Kontaktirajte nas za informacije o dogodku in partnerstvu.' },
	hu: { title: 'KAPCSOLAT', subtitle: 'Vegye fel velünk a kapcsolatot eseményinformációkért és partneri megkeresésekhez.' },
	no: { title: 'KONTAKT', subtitle: 'Kontakt oss for informasjon om arrangementet og partnerskap.' },
	sv: { title: 'KONTAKT', subtitle: 'Kontakta oss för information om evenemanget och partnerskap.' },
	nl: { title: 'CONTACT', subtitle: 'Neem contact met ons op voor informatie over het evenement en partnerschappen.' },
	es: { title: 'CONTACTO', subtitle: 'Póngase en contacto con nosotros para información del evento y colaboraciones.' },
	pt: { title: 'CONTACTO', subtitle: 'Entre em contacto connosco para detalhes do evento e parcerias.' },
	ro: { title: 'CONTACT', subtitle: 'Contactați-ne pentru informații despre eveniment și parteneriate.' },
	it: { title: 'CONTATTO', subtitle: "Contattaci per dettagli sull'evento e richieste di partnership." },
	ko: { title: '문의', subtitle: '행사 정보 및 파트너십 문의는 여기로 연락해 주세요.' },
};
const ctHero = contactHero[lang] ?? contactHero.pl;

const zipCity = [s?.contact_address_zip?.trim(), s?.contact_address_city?.trim()].filter(Boolean).join(' ');
const contactStreet = s?.contact_address_street?.trim();
const contactAddressLine =
	[contactStreet, zipCity].filter(Boolean).join(', ') || 'ul. Odolanowska 17, 63-400 Topola Mała';
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	localizedPath="kontakt"
	ogType="website"
	canonicalHref={canonicalHref}
>
	<NavBar lang={lang} client:load logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} navLinks={cmsNavLinks} />
	<PageHero
		category={ctHero.title}
		title={ctHero.title}
		subtitle={ctHero.subtitle}
		heroImage={s?.hero_background_image}
		heroOpacity={s?.hero_background_opacity}
	/>
	<ContactPage
		lang={lang}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.contact_phone_sebastian}
		address={contactAddressLine}
		mapEmbedUrl={s?.contact_map_embed_url}
		venueAddress={s?.contact_venue_address}
		presidentEmail={s?.contact_president_email ?? s?.president_email}
		contactFormEndpoint={s?.contact_form_endpoint}
		contactFormRecipient={s?.contact_form_recipient}
		gdprConsentText={lang === 'pl' ? s?.contact_gdpr_text_pl : s?.contact_gdpr_text_en}
		client:load
	/>
	<Footer
		lang={lang}
		copy={footerCopyByLang[lang] ?? footerCopyByLang['pl']}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		address={s?.footer_address}
		foundationName={s?.footer_foundation_name}
		domains={s?.footer_domains}
		krsNumber={s?.krs_number}
		nipNumber={s?.nip_number}
		regonNumber={s?.regon_number}
		client:load
	/>
</BaseLayout>
