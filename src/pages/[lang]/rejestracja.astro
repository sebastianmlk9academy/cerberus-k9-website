---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales } from '../../../locales.mjs';
import { footerCopyByLang } from '../../i18n/footer';
import { isLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import RegistrationSection from '../../components/RegistrationSection.astro';
import { Footer } from '../../components/Footer';
import { getSortedNavLinks } from '../../lib/getSortedNavLinks';
import { RegistrationPaths } from '../../components/RegistrationPaths';

export const prerender = true;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;

const paths = (await getCollection('registration_paths'))
	.filter((p) => p.data.isVisible)
	.sort((a, b) => a.data.order - b.data.order)
	.map((p) => p.data);

let regInfo = null;
try {
	const ri = await getEntry('registration_info', 'registration_info');
	regInfo = ri?.data ?? null;
} catch {
	regInfo = null;
}

/** Polish URL is canonical; /pl/rejestracja is defined in `src/pages/pl/rejestracja.astro`. */
export function getStaticPaths() {
	return locales.filter((l) => l !== 'pl').map((lang) => ({ params: { lang } }));
}

const { lang: paramLang } = Astro.params;
const lang: Lang = isLang(paramLang ?? '') ? (paramLang as Lang) : 'en';
const navLinks = await getSortedNavLinks(lang);

const title = lang === 'pl' ? 'Rejestracja — CERBERUS K9' : 'Registration — CERBERUS K9';
const description =
	lang === 'pl'
		? 'Zarejestruj się bezpłatnie na CERBERUS K9 2026. 13-14 czerwca, Ostrów Wielkopolski. 250+ uczestników z 15+ krajów NATO.'
		: 'Register for CERBERUS K9 2026. June 13-14, Ostrow Wielkopolski. 250+ participants from 15+ NATO countries.';
const canonicalHref = `/${lang}/rejestracja`;
const regHero: Record<Lang, { category: string; title: string; subtitle: string }> = {
	pl: {
		category: 'DOŁĄCZ DO NAS',
		title: 'REJESTRACJA',
		subtitle: 'Zarejestruj się na CERBERUS K9 i potwierdź bezpłatny udział w wydarzeniu.',
	},
	en: {
		category: 'JOIN US',
		title: 'REGISTRATION',
		subtitle: 'Register for CERBERUS K9 and confirm your free event participation.',
	},
	de: {
		category: 'MITMACHEN',
		title: 'REGISTRIERUNG',
		subtitle: 'Registrieren Sie sich für CERBERUS K9 und bestätigen Sie Ihre kostenlose Teilnahme.',
	},
	fr: {
		category: 'REJOIGNEZ-NOUS',
		title: 'INSCRIPTION',
		subtitle: "Inscrivez-vous à CERBERUS K9 et confirmez votre participation gratuite à l'événement.",
	},
	hr: {
		category: 'PRIDRUŽITE NAM SE',
		title: 'REGISTRACIJA',
		subtitle: 'Registrirajte se za CERBERUS K9 i potvrdite besplatan ulaz na događaj.',
	},
	cs: {
		category: 'PŘIPOJTE SE K NÁM',
		title: 'REGISTRACE',
		subtitle: 'Zaregistrujte se na CERBERUS K9 a potvrďte svou bezplatnou účast na akci.',
	},
	lt: {
		category: 'PRISIJUNKITE PRIE MŪSŲ',
		title: 'REGISTRACIJA',
		subtitle: 'Užsiregistruokite į CERBERUS K9 ir patvirtinkite nemokamą dalyvavimą renginyje.',
	},
	lv: {
		category: 'PIEVIENOJIETIES MUMS',
		title: 'REĢISTRĀCIJA',
		subtitle: 'Reģistrējieties CERBERUS K9 un apstipriniet savu bezmaksas dalību pasākumā.',
	},
	sk: {
		category: 'PRIDAJTE SA K NÁM',
		title: 'REGISTRÁCIA',
		subtitle: 'Zaregistrujte sa na CERBERUS K9 a potvrďte svoju bezplatnú účasť na podujatí.',
	},
	sl: {
		category: 'PRIDRUŽITE SE NAM',
		title: 'REGISTRACIJA',
		subtitle: 'Registrirajte se na CERBERUS K9 in potrdite brezplačno udeležbo na dogodku.',
	},
	hu: {
		category: 'CSATLAKOZZON HOZZÁNK',
		title: 'REGISZTRÁCIÓ',
		subtitle: 'Regisztráljon a CERBERUS K9 eseményre, és erősítse meg ingyenes részvételét.',
	},
	no: {
		category: 'BLI MED OSS',
		title: 'REGISTRERING',
		subtitle: 'Registrer deg for CERBERUS K9 og bekreft gratis deltakelse på arrangementet.',
	},
	sv: {
		category: 'GÅ MED OSS',
		title: 'REGISTRERING',
		subtitle: 'Registrera dig för CERBERUS K9 och bekräfta gratis deltagande i evenemanget.',
	},
	nl: {
		category: 'DOE MEE',
		title: 'REGISTRATIE',
		subtitle: 'Registreer je voor CERBERUS K9 en bevestig je gratis deelname aan het evenement.',
	},
	es: {
		category: 'ÚNETE A NOSOTROS',
		title: 'REGISTRO',
		subtitle: 'Regístrese en CERBERUS K9 y confirme su participación gratuita en el evento.',
	},
	pt: {
		category: 'JUNTE-SE A NÓS',
		title: 'REGISTO',
		subtitle: 'Registe-se no CERBERUS K9 e confirme a sua participação gratuita no evento.',
	},
	ro: {
		category: 'ALĂTURAȚI-VĂ NOUĂ',
		title: 'ÎNREGISTRARE',
		subtitle: 'Înregistrați-vă la CERBERUS K9 și confirmați participarea gratuită la eveniment.',
	},
	it: {
		category: 'UNISCITI A NOI',
		title: 'REGISTRAZIONE',
		subtitle: "Registrati a CERBERUS K9 e conferma la tua partecipazione gratuita all'evento.",
	},
	ko: {
		category: '함께하세요',
		title: '등록',
		subtitle: 'CERBERUS K9에 등록하고 무료 행사 참여를 확정하세요.',
	},
};
const regH = regHero[lang] ?? regHero.pl;
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	localizedPath="rejestracja"
	ogType="website"
	canonicalHref={canonicalHref}
	robots="noindex, follow"
>
	<NavBar lang={lang} client:load logoSrc={s?.nav_logo} logoAlt={s?.nav_logo_alt} brandName={s?.brand_name} brandTagline={s?.brand_tagline} links={navLinks} activeHref={Astro.url.pathname} registrationActive={s?.registration_active ?? true} registrationHref={(s?.pretix_url?.trim() || s?.hero_cta_registration_href?.trim()) || undefined} />
	<div style="background: linear-gradient(to bottom, #161F28, #1A2530, #161F28);">
		<PageHero
			category={regH.category}
			title={regH.title}
			subtitle={regH.subtitle}
			heroImage={s?.hero_background_image}
			heroOpacity={s?.hero_background_opacity}
		/>
		<RegistrationPaths
			client:load
			paths={paths}
			lang={lang}
			fallbackUrl={s?.registration_url ?? s?.pretix_url}
		/>
		{
			!s?.registration_active ? (
				<section style="background:#161F28; padding:80px 5%; text-align:center;">
					<p
						style="font-family:Rajdhani,sans-serif; font-size:11px; letter-spacing:3px; color:#C4922A; font-weight:700;"
					>
						{lang === 'pl'
							? 'REJESTRACJA NIEDOSTĘPNA — SPRAWDŹ PONOWNIE PÓŹNIEJ'
							: 'REGISTRATION UNAVAILABLE — CHECK BACK LATER'}
					</p>
				</section>
			) : (
				<!-- Legacy: sidebar fields below are emergency fallback. Canonical: registration_info collection. -->
				<RegistrationSection
					lang={lang}
					pretixUrl={s?.pretix_url}
					dateValue={s?.registration_date_display}
					prepDay={s?.registration_prep_day}
					venues={s?.registration_venues}
					city={s?.registration_city}
					contactEmail={s?.registration_contact_email}
					contactPhone={s?.registration_contact_phone}
					regDateDisplay={
						regInfo?.reg_date_display ?? s?.registration_date_display ?? '13–14 czerwca 2026'
					}
					regPrepDay={regInfo?.reg_prep_day ?? s?.registration_prep_day}
					regVenues={regInfo?.reg_venues ?? s?.registration_venues}
					regCity={regInfo?.reg_city ?? s?.registration_city ?? 'Ostrów Wielkopolski'}
					regContactEmail={
						regInfo?.reg_contact_email ?? s?.registration_contact_email ?? s?.footer_email ?? 'sebastian@pactak9.org'
					}
					regContactPhone={regInfo?.reg_contact_phone ?? s?.registration_contact_phone ?? s?.footer_phone}
					regEntryText={regInfo?.reg_entry_text}
					regDeadlineText={regInfo?.reg_deadline_text ?? s?.registration_deadline_text}
					regLimitText={regInfo?.reg_limit_text}
					regStep1Pl={lang === 'pl' ? regInfo?.reg_step_1_pl : undefined}
					regStep2Pl={lang === 'pl' ? regInfo?.reg_step_2_pl : undefined}
					regStep3Pl={lang === 'pl' ? regInfo?.reg_step_3_pl : undefined}
					presidentEmail={
						s?.contact_president_email?.trim() ||
							s?.president_email?.trim() ||
							'mariusz@pactak9.org'
					}
				/>
			)
		}
	</div>
	<Footer
		lang={lang}
		copy={footerCopyByLang[lang] ?? footerCopyByLang['pl']}
		logoSrc={s?.nav_logo}
		logoAlt={s?.nav_logo_alt}
		brandName={s?.brand_name}
		brandTagline={s?.brand_tagline}
		email={s?.footer_email ?? s?.registration_contact_email}
		phone={s?.footer_phone ?? s?.contact_phone_sebastian}
		socialFacebook={s?.social_facebook}
		socialYoutube={s?.social_youtube}
		socialInstagram={s?.social_instagram}
		socialLinkedin={s?.social_linkedin}
		socialTwitter={s?.social_twitter}
		footerLinks={{
			about: s?.footer_link_about,
			instructors: s?.footer_link_instructors,
			registration: s?.footer_link_registration,
			program: s?.footer_link_program,
			gallery: s?.footer_link_gallery,
			media: s?.footer_link_media,
			news: s?.footer_link_news,
			foundation: s?.footer_link_foundation,
			partners: s?.footer_link_partners,
			contact: s?.footer_link_contact,
		}}
	/>
</BaseLayout>
