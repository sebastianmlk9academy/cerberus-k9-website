---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { locales } from '../../../locales.mjs';
import { isLang } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';
import { NavBar } from '../../components/NavBar';
import { PageHero } from '../../components/PageHero';
import RegistrationEmbed from '../../components/RegistrationEmbed';
import { Footer } from '../../components/Footer';

export const prerender = true;

/** Polish URL is canonical; /pl/rejestracja is defined in `src/pages/pl/rejestracja.astro`. */
export function getStaticPaths() {
	return locales.filter((l) => l !== 'pl').map((lang) => ({ params: { lang } }));
}

const param = Astro.params.lang ?? '';
const lang: Lang = isLang(param) ? param : 'en';

const title = 'Rejestracja — CERBERUS K9 2026 | Bezpłatna rejestracja online';
const description =
	'Zarejestruj się bezpłatnie na CERBERUS K9 2026. 13-14 czerwca, Ostrów Wielkopolski. 250+ uczestników z 15+ krajów NATO.';
const canonicalHref = '/pl/rejestracja/';
---

<BaseLayout
	lang={lang}
	title={title}
	description={description}
	localizedPath="rejestracja"
	ogType="website"
	canonicalHref={canonicalHref}
	robots="noindex, follow"
>
	<link
		slot="head"
		rel="stylesheet"
		href="https://pretix.eu/static/pretixwidget/widget.css"
	/>
	<script
		slot="head"
		src="https://pretix.eu/static/pretixwidget/widget.js"
		async
	></script>
	<NavBar client:load />
	<PageHero
		category="DOŁĄCZ DO NAS"
		title="REJESTRACJA"
		subtitle="WSTĘP BEZPŁATNY · WYMAGANA REJESTRACJA · 13–14 CZERWCA 2026"
	/>
	<RegistrationEmbed client:only="react" />
	<Footer client:load />
</BaseLayout>
