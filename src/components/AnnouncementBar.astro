---
interface Props {
	active: boolean;
	text?: string;
	url?: string;
}
const { active, text, url } = Astro.props;
---

{
	active && text && (
		<div
			style="background:#C4922A; color:#0F1720; text-align:center; padding:8px 16px; font-family:Rajdhani,sans-serif; font-size:12px; font-weight:700; letter-spacing:3px; z-index:100;"
		>
			{url ? (
				<a href={url} style="color:#0F1720; text-decoration:none;">
					{text} →
				</a>
			) : (
				text
			)}
		</div>
	)
}
