---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	ogImage?: string;
	/** When no `ogImage` / page image, use CMS default OG asset path. */
	ogImageDefault?: string;
	ogType?: string;
	/** When set, overrides default pathname-based canonical (e.g. consolidated registration URL). */
	canonicalHref?: string;
	/** When set, emitted as `<meta name="robots" />` (e.g. `noindex, follow` for non-canonical locales). */
	robots?: string;
	/** Twitter @handle for `twitter:site` (from CMS). */
	twitterHandle?: string;
	/** `summary_large_image` for articles and large previews (default). */
	twitterCard?: string;
	appleTouchIcon?: string;
	faviconSvg?: string;
	faviconIco?: string;
	ogImageWidth?: string;
	ogImageHeight?: string;
	ogImageAlt?: string;
	ogSiteName?: string;
	ogLocale?: string;
	orgName?: string;
	orgUrl?: string;
	orgPhone?: string;
	orgEmail?: string;
	orgLogo?: string;
	socialFacebook?: string;
	socialYoutube?: string;
	/** PWA / browser UI accent (`<meta name="theme-color" />`). */
	themeColor?: string;
	/** Web app manifest URL (default `/manifest.json`). */
	manifestHref?: string;
}

const {
	title,
	description,
	image = FallbackImage,
	ogImage,
	ogImageDefault,
	ogType = 'website',
	canonicalHref,
	robots,
	twitterHandle = '@cerberusk9',
	twitterCard = 'summary_large_image',
	appleTouchIcon = '/apple-touch-icon.png',
	faviconSvg = '/favicon.svg',
	faviconIco = '/favicon.ico',
	ogImageWidth = '1200',
	ogImageHeight = '630',
	ogImageAlt = 'CERBERUS K9 2026 — Międzynarodowa Platforma Obrony',
	ogSiteName = 'CERBERUS K9',
	ogLocale = 'pl_PL',
	orgName = 'Fundacja PACTA K9',
	orgUrl = 'https://pactak9.org',
	orgPhone,
	orgEmail,
	orgLogo = '/images/cerberus-k9-logo.png',
	socialFacebook,
	socialYoutube,
	themeColor = '#0F1720',
	manifestHref = '/manifest.json',
} = Astro.props;

const canonicalURL = canonicalHref
	? new URL(canonicalHref, Astro.site)
	: new URL(Astro.url.pathname, Astro.site);
const canonicalHrefStr = canonicalURL.href;

const safeOgImage = ogImage ?? image?.src ?? ogImageDefault ?? '/og-cerberus-k9-2026.jpg';
const resolvedOgImage = new URL(safeOgImage, Astro.site ?? Astro.url).toString();

const logoAbs = new URL(orgLogo, Astro.site ?? Astro.url).href;
const sameAs = [socialFacebook, socialYoutube].filter((u): u is string => Boolean(u?.trim()));

const orgJsonLd: Record<string, unknown> = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: orgName,
	url: orgUrl,
	logo: logoAbs,
};
if (orgPhone || orgEmail) {
	orgJsonLd.contactPoint = {
		'@type': 'ContactPoint',
		...(orgPhone ? { telephone: orgPhone } : {}),
		...(orgEmail ? { email: orgEmail } : {}),
		contactType: 'general',
	};
}
if (sameAs.length > 0) {
	orgJsonLd.sameAs = sameAs;
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content={themeColor} />
<link rel="manifest" href={manifestHref} />
<link rel="icon" type="image/svg+xml" href={faviconSvg} />
<link rel="icon" href={faviconIco} />
<link rel="apple-touch-icon" href={appleTouchIcon} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHrefStr} />

{robots && <meta name="robots" content={robots} />}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook, LinkedIn, WhatsApp -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalHrefStr} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:width" content={ogImageWidth} />
<meta property="og:image:height" content={ogImageHeight} />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:site_name" content={ogSiteName} />
<meta property="og:locale" content={ogLocale} />

<!-- Twitter -->
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:url" content={canonicalHrefStr} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
