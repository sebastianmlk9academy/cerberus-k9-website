---
import { Image } from 'astro:assets';
import { type CollectionEntry, getEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { noindex?: boolean };

const { title, description, pubDate, updatedDate, heroImage, noindex } = Astro.props;
const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const twitterHandle = s?.twitter_handle ?? '@cerberusk9';
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			twitterHandle={twitterHandle}
			ogImageDefault={s?.og_image_default}
			appleTouchIcon={s?.apple_touch_icon}
			faviconSvg={s?.favicon_svg}
			faviconIco={s?.favicon_ico}
			ogImageWidth={s?.og_image_width}
			ogImageHeight={s?.og_image_height}
			ogImageAlt={s?.og_image_alt}
			ogSiteName={s?.og_site_name}
			ogLocale={s?.og_locale}
			orgName={s?.footer_foundation_name}
			orgUrl={s?.site_url}
			orgPhone={s?.footer_phone}
			orgEmail={s?.footer_email}
			orgLogo={s?.nav_logo}
			socialFacebook={s?.social_facebook}
			socialYoutube={s?.social_youtube}
		/>
		{noindex ? <meta name="robots" content="noindex, nofollow" /> : null}
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
