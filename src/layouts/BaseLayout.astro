---
import { getEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import CookieConsent, { ConsentProvider } from '@/components/CookieConsent';
import Trackers from '@/components/Trackers';
import NotificationBar from '@/components/NotificationBar';
import MobileStickyCTA from '@/components/MobileStickyCTA';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { getAbsoluteLocaleUrlList } from 'astro:i18n';
import { locales } from '../../locales.mjs';

interface Props {
	lang: string;
	title: string;
	description: string;
	localizedPath?: string;
	image?: ImageMetadata;
	ogImage?: string;
	/** Overrides CMS `og_image_default` when set; otherwise CMS default is passed to BaseHead. */
	ogImageDefault?: string;
	ogType?: string;
	canonicalHref?: string;
	robots?: string;
	/** When true, emit only pl + x-default alternates (use with canonicalHref for PL-only routes). */
	omitLocaleAlternates?: boolean;
	/** When true, emit only en + x-default (both point to English international URL). */
	internationalHreflangOnly?: boolean;
	twitterHandle?: string;
	twitterCard?: string;
}

const {
	lang,
	title,
	description,
	localizedPath = '',
	image,
	ogImage,
	ogImageDefault: ogImageDefaultProp,
	ogType,
	canonicalHref,
	robots,
	omitLocaleAlternates = false,
	internationalHreflangOnly = false,
	twitterHandle: twitterHandleProp,
	twitterCard,
} = Astro.props;

const settings = await getEntry('ustawienia', 'ustawienia');
const s = settings?.data;
const twitterHandle = twitterHandleProp ?? s?.twitter_handle ?? '@cerberusk9';
const ogImageDefaultForHead = ogImageDefaultProp ?? s?.og_image_default;

const alternates = omitLocaleAlternates ? [] : getAbsoluteLocaleUrlList(localizedPath);
const plIndex = locales.indexOf('pl');
const xDefaultHref = alternates[plIndex >= 0 ? plIndex : 0];
const canonicalAlternateHref = (
	canonicalHref && canonicalHref.length > 0
		? new URL(canonicalHref, Astro.site)
		: new URL(Astro.url.pathname, Astro.site)
).href;

const internationalHref = new URL('/en/international', Astro.site).href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image ?? FallbackImage}
			ogImage={ogImage}
			ogImageDefault={ogImageDefaultForHead}
			ogType={ogType}
			canonicalHref={canonicalHref}
			robots={robots}
			twitterHandle={twitterHandle}
			twitterCard={twitterCard}
			rssFeedTitle={s?.brand_name ?? 'CERBERUS K9'}
			appleTouchIcon={s?.apple_touch_icon}
			faviconSvg={s?.favicon_svg}
			faviconIco={s?.favicon_ico}
			ogImageWidth={s?.og_image_width}
			ogImageHeight={s?.og_image_height}
			ogImageAlt={s?.og_image_alt}
			ogSiteName={s?.og_site_name}
			ogLocale={s?.og_locale}
			orgName={s?.footer_foundation_name}
			orgUrl={s?.site_url}
			orgPhone={s?.footer_phone}
			orgEmail={s?.footer_email}
			orgLogo={s?.nav_logo}
			socialFacebook={s?.social_facebook}
			socialYoutube={s?.social_youtube}
		/>
		<slot name="head" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Libre+Baskerville:wght@400;700&family=Rajdhani:wght@400;500;600;700&display=swap"
		/>
		{
			internationalHreflangOnly ? (
				<>
					<link rel="alternate" hreflang="en" href={internationalHref} />
					<link rel="alternate" hreflang="x-default" href={internationalHref} />
				</>
			) : omitLocaleAlternates ? (
				<>
					<link rel="alternate" hreflang="pl" href={canonicalAlternateHref} />
					<link rel="alternate" hreflang="x-default" href={canonicalAlternateHref} />
				</>
			) : (
				<>
					{locales.map((locale, i) => (
						<link rel="alternate" hreflang={locale} href={alternates[i]} />
					))}
					<link rel="alternate" hreflang="x-default" href={xDefaultHref} />
				</>
			)
		}
	</head>
	<body class="min-h-screen bg-navyDeep font-sans text-bone antialiased">
		<a
			href="#main-content"
			style="position: absolute; top: -40px; left: 0; background: #C4922A; color: #0F1720; padding: 8px 16px; font-family: Rajdhani, sans-serif; font-weight: 700; font-size: 12px; letter-spacing: 2px; text-decoration: none; z-index: 9999; transition: top 0.2s;"
			onfocus="this.style.top='0'"
			onblur="this.style.top='-40px'">
			PRZEJDŹ DO TREŚCI
		</a>
		<ConsentProvider client:load policyVersion={s?.consent_version ?? 1} />
		<NotificationBar
			client:load
			isActive={s?.notification_bar_active ?? false}
			messagePl={s?.notification_bar_text_pl ?? s?.notification_bar_text ?? ''}
			messageEn={s?.notification_bar_text_en ?? ''}
			lang={lang}
			linkText={
				lang === 'en'
					? (s?.notification_bar_link_text_en ?? undefined)
					: (s?.notification_bar_link_text_pl ?? undefined)
			}
			linkHref={s?.notification_bar_url ?? undefined}
			severity={s?.notification_bar_severity ?? 'info'}
		/>
		<slot name="header" />
		<div id="main-content">
			<slot />
		</div>
		<slot name="footer" />
		<CookieConsent client:idle lang={lang} active={s?.cookie_consent_active ?? false} />
		<Trackers
			client:idle
			ga4Id={s?.ga4_id}
			plausibleDomain={s?.plausible_domain}
			microsoftClarityId={s?.microsoft_clarity_id}
			facebookPixelId={s?.facebook_pixel_id}
		/>
		<MobileStickyCTA
			client:load
			isActive={s?.mobile_sticky_cta_active ?? false}
			href={s?.registration_url ?? s?.pretix_url ?? s?.hero_cta_registration_href ?? '#'}
			lang={lang}
			labelPl={s?.mobile_cta_label_pl ?? 'ZAREJESTRUJ SIĘ'}
			labelEn={s?.mobile_cta_label_en ?? 'REGISTER NOW'}
			hideOnPaths={['/rejestracja', '/registration']}
		/>
	</body>
</html>
